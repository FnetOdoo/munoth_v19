<odoo>
    <record id="view_battery_cell_log_list" model="ir.ui.view">
        <field name="name">battery.cell.log.list</field>
        <field name="model">battery.cell.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="serial_number"/>
                <field name="creation_time"/>
                <field name="model_br"/>
                <field name="battery_voltage_v"/>
                <field name="voltage_pass_ng_br"/>
                <field name="battery_weight_pass_ng"/>
                <field name="encapsulation_id_br"/>
                <field name="vsn_br"/>
                <field name="equipment_number"/>
                <field name="bar_code_pass_ng_br"/>
                <field name="status_br"/>
                <field name="bar_code"/>
                <field name="side_voltage"/>
                <field name="side_voltage_ng"/>
                <field name="battery_weight"/>
                <field name="residual_liquid"/>
                <field name="residual_liquid_ng"/>
                <field name="package_upper"/>
                <field name="encapsulation_lower"/>
                <field name="encapsulation_pre"/>
                <field name="packaging_time"/>
                <field name="encapsulation_vacuum"/>
                <field name="vacuum_time"/>
                <field name="on_seal"/>
                <field name="under_seal"/>
                <field name="time_seal"/>
            </list>
        </field>
    </record>

    <record id="view_battery_cell_log_form" model="ir.ui.view">
        <field name="name">battery.cell.log.form</field>
        <field name="model">battery.cell.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="serial_number"/>
                        <field name="creation_time"/>
                        <field name="model_br"/>
                        <field name="battery_voltage_v"/>
                        <field name="voltage_pass_ng_br"/>
                        <field name="battery_weight_pass_ng"/>
                        <field name="encapsulation_id_br"/>
                        <field name="vsn_br"/>
                        <field name="equipment_number"/>
                        <field name="bar_code_pass_ng_br"/>
                        <field name="status_br"/>
                        <field name="bar_code"/>
                        <field name="side_voltage"/>
                        <field name="side_voltage_ng"/>
                        <field name="battery_weight"/>
                        <field name="residual_liquid"/>
                        <field name="residual_liquid_ng"/>
                        <field name="package_upper"/>
                        <field name="encapsulation_lower"/>
                        <field name="encapsulation_pre"/>
                        <field name="packaging_time"/>
                        <field name="encapsulation_vacuum"/>
                        <field name="vacuum_time"/>
                        <field name="on_seal"/>
                        <field name="under_seal"/>
                        <field name="time_seal"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="action_battery_cell_log" model="ir.actions.act_window">
        <field name="name">Battery Cell Logs</field>
        <field name="res_model">battery.cell.log</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_battery_cell_root" name="API Logs" sequence="1000"
              web_icon="battery_cell_api,static/description/icon.png" groups="base.group_no_one"/>
    <menuitem id="menu_battery_cell_log" name="Battery Logs" parent="menu_battery_cell_root"
              action="action_battery_cell_log" sequence="1" groups="base.group_no_one"/>

