<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Manufacturing Category (already in base, just update) -->
        <record id="base.module_category_manufacturing" model="ir.module.category">
            <field name="name">Manufacturing</field>
            <field name="description">Helps you manage your manufacturing processes and generate reports on those processes.</field>
            <field name="sequence">5</field>
        </record>

        <!-- Manufacturing Privilege -->
        <record id="privilege_manufacturing" model="res.groups.privilege">
            <field name="name">Manufacturing</field>
            <field name="sequence">5</field>
            <field name="category_id" ref="base.module_category_manufacturing"/>
        </record>

        <record id="group_manufacturing_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="privilege_manufacturing"/>
            <field name="implied_ids" eval="[Command.link(ref('stock.group_stock_user'))]"/>
        </record>

        <record id="group_manufacturing_manager" model="res.groups">
            <field name="name">Administrator</field>
            <field name="privilege_id" ref="privilege_manufacturing"/>
            <field name="implied_ids" eval="[Command.link(ref('group_manufacturing_user'))]"/>
        </record>

        <!-- Cell Design Category -->
        <record id="module_category_cell_design" model="ir.module.category">
            <field name="name">Cell Design</field>
            <field name="sequence">100</field>
        </record>

        <!-- Cell Design Privilege -->
        <record id="privilege_cell_design" model="res.groups.privilege">
            <field name="name">Cell Design</field>
            <field name="sequence">100</field>
            <field name="category_id" ref="module_category_cell_design"/>
        </record>

        <record id="group_cell_design_user" model="res.groups">
            <field name="name">Design User</field>
            <field name="privilege_id" ref="privilege_cell_design"/>
            <field name="implied_ids" eval="[Command.link(ref('base.group_user'))]"/>
        </record>

        <record id="group_cell_design_approver" model="res.groups">
            <field name="name">Approver</field>
            <field name="privilege_id" ref="privilege_cell_design"/>
            <field name="implied_ids" eval="[Command.link(ref('fnet_mrp.group_cell_design_user'))]"/>
        </record>

        <!-- MRP Quality Category -->
        <record id="module_category_mrp_quality" model="ir.module.category">
            <field name="name">MRP Quality</field>
            <field name="sequence">100</field>
        </record>

        <!-- MRP Quality Privilege -->
        <record id="privilege_mrp_quality" model="res.groups.privilege">
            <field name="name">MRP Quality</field>
            <field name="sequence">100</field>
            <field name="category_id" ref="module_category_mrp_quality"/>
        </record>

        <record id="group_mrp_quality_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="privilege_mrp_quality"/>
            <field name="implied_ids" eval="[Command.link(ref('base.group_user'))]"/>
        </record>

        <record id="group_mrp_quality_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="privilege_mrp_quality"/>
            <field name="implied_ids" eval="[Command.link(ref('group_mrp_quality_user'))]"/>
        </record>

        <!-- Hidden group - no category/privilege needed in Odoo 19 -->
        <record id="group_stock_inspection_approve" model="res.groups">
            <field name="name">Stock Inspection Manager Approve</field>
        </record>

    </data>
</odoo>