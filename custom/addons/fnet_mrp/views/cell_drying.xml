<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <data>
        <!-- Injection-->

        <record id="cell_drying_process_form_view" model="ir.ui.view">
            <field name="name">cell.drying.form</field>
            <field name="model">cell.drying</field>
            <field name="priority">100</field>
            <field name="arch" type="xml">
                <form string="Cell Drying" duplicate="0" delete="0">
                    <header>
                        <button name="action_start" string="Start" type="object" invisible="state != 'draft'" class="oe_highlight"/>
                        <button name="check_available_stock" string="Check Availability" type="object" invisible="state != 'draft'"/>
                        <button name="action_done_production" string="Production Done" class="btn-success" invisible="state != 'progress'" type="object"/>
                        <button name="action_close" string="Close" type="object" invisible="state != 'done'" class="oe_highlight"/>
                        <button name="action_break_production" string="Pause Production" invisible="state != 'progress'" class="btn-danger" type="object"/>
                        <button name="action_restart_production" string="Restart Production" invisible="state != 'hold'" class="btn-success" type="object"/>
                        <button name="create_scrap_product" string="Rejection" class="btn-strong" invisible="state != 'close'" type="object"/>
                        <!--                <button name="action_request_process_approval" string="Request Process Approval"-->
                        <!--                        class="btn-warning" type="object"-->
                        <!--                        invisible="process_status_check == True"/>-->
                        <field name="state" widget="statusbar" statusbar_visible="draft,progress,done" readonly="1" clickable="1"/>
                    </header>

                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" string="In Process Quality" name="action_view_in_process_quality" type="object" icon="fa-check" invisible="state in ('draft', 'confirmed', 'cancel')"/>
                            <button class="oe_stat_button" string="Quality" name="action_view_quality" type="object" icon="fa-check" invisible="state in ('draft', 'confirmed', 'progress', 'done')"/>
                            <button class="oe_stat_button" string="Stock Move" name="action_view_product_move" type="object" icon="fa-exchange" invisible="state == 'draft'"/>
                            <button class="oe_stat_button" name="action_assembly_record_record" type="object" invisible="assembly_count == 0" icon="fa-arrow-left">
                                <field name="assembly_count" widget="statinfo" string="Assembly Cell"/>
                            </button>
                            <button class="oe_stat_button" name="show_cell_injection_record" type="object" invisible="injection_count == 0" icon="fa-arrow-right">
                                <field name="injection_count" widget="statinfo" string="Injection"/>
                            </button>
                            <button class="oe_stat_button" name="action_open_process_approval" type="object" invisible="pa_count == 0" icon="fa-pencil">
                                <field name="pa_count" widget="statinfo" string="Process Approval"/>
                            </button>
                            <button class="oe_stat_button" name="show_clamp_baking_record" type="object" invisible="clamp_baking_count == 0" icon="fa-arrow-right">
                                <field name="clamp_baking_count" widget="statinfo" string="Clamp Baking"/>
                            </button>
                            <button name="action_create_clamp_baking" icon="fa-pencil" string="Create Clamp Baking" invisible="choose_stage != 'stage_3' or state != 'close'" type="object"/>
                            <button name="action_create_injection_cell" icon="fa-pencil" string="Create Injection Cell" invisible="choose_stage == 'stage_3' or state != 'close'" type="object"/>
                            <button name="action_view_lots" type="object" string="Show Lots" icon="fa-list"/>
                        </div>

                        <div class="oe_title">
                            <label for="name" string="Reference"/>
                            <h1>
                                <field name="name" readonly="1"/>
                                <field name="process_status_check" invisible="1"/>
                            </h1>
                        </div>

                        <group>
                            <group>
                                <field name="production_plan_id" required="1" readonly="state != 'draft'"/>
                                <field name="choose_stage" readonly="state != 'draft'"/>
                                <field name="product_model_id" required="1" string="Model" readonly="state != 'draft'"/>
                                <field name="machine_id" required="1" domain="['|', ('type', '=', type), ('type', '=', False)]" readonly="state != 'draft'"/>
                                <field name="operation_id" domain="[('product_model_id', '=', product_model_id), ('type', '=', type)]" readonly="state != 'draft'"/>
                                <field name="product_id" force_save="1" required="0" domain="[('type', 'in', ['product', 'consu']), '|', ('company_id', '=', False), ('company_id', '=', company_id)]"/>
                                <field name="product_tracking" required="0" invisible="1"/>
                                <field name="product_tmpl_id" invisible="1"/>
                                <field name="product_qty" readonly="state in ('done', 'close')"/>
                                <field name="product_uom_id" invisible="1"/>
                            </group>
                            <group>
                                <!--                        <field name="assembly_id" />-->
                                <field name="bom_id" domain="[('product_tmpl_id', '=', product_id), ('product_model_id', '=', product_model_id)]" invisible="0" readonly="state != 'draft'"/>
                                <field name="qty_producing" invisible="1"/>
                                <field name="product_uom_category_id" invisible="1"/>
                                <field name="product_uom_qty" invisible="1"/>
                                <field name="company_id" invisible="1"/>
                                <field name="start_time" readonly="1"/>
                                <label for="expected_end_time" invisible="not start_time"/>
                                <div invisible="not start_time">
                                    <field name="expected_end_time" nolabel="1" class="oe_inline"/>
                                    <span invisible="end_time != False">
                                        /
                                        <field name="remaining_hours" widget="float_time" nolabel="1" class="oe_inline"/>
                                        Hours Remaining
                                    </span>
                                </div>
                                <field name="end_time" readonly="1"/>
                                <field name="user_id" readonly="1"/>
                                <!--                        <field name="qty_produced"  attrs="{'invisible': [('state', 'in', ['draft', 'confirmed'])] , 'readonly' : [('state', 'in', ['draft', 'confirmed', 'done', 'close'])]}"/>-->
                                <!--                        <field name="product_tray_id" invisible="1"/>-->
                            </group>
                        </group>

                        <notebook>
                            <page string="Materials" name="input">
                                <field name="input_material_lines" readonly="state in ('done', 'close')"/>
                            </page>

                            <page string="Detailed Materials" name="materials">
                                <group>
                                    <div>
                                        <button name="action_remove_line" type="object" string="Remove All" invisible="state in ('done', 'close')"/>
                                    </div>
                                </group>
                                <field name="component_ids" readonly="state in ('done', 'close')"/>
                            </page>

                            <page string="Serial Number" invisible="state in ('done', 'close')">
                                <group>
                                    <group string="From Material Tab">
                                        <div>
                                            <button name="get_serial_numbers" type="object" string="Get All Serial"/>
                                            <button name="clear_serial_numbers" type="object" string="Clear All Serial"/>
                                        </div>
                                    </group>
                                    <group string="Upload file">
                                        <div>
                                            <field name="out_file_name" invisible="1"/>
                                            <field name="out_file" filename="out_file_name"/>
                                            <button name="action_upload_serial" type="object" string="Upload Serial"/>
                                            <button name="action_download_sample" type="object" string="Download Sample"/>
                                        </div>
                                    </group>
                                </group>
                                <field name="lot_ids" context="{'default_product_id': product_id, 'default_product_uom_id': product_uom_id}">
                                    <list editable="bottom">
                                        <field name="name" required="1" string="Serial Number"/>
                                        <field name="product_id" column_invisible="0" groups="base.group_no_one"/>
                                        <field name="product_uom_category_id" column_invisible="1"/>
                                        <field name="product_uom_id" column_invisible="0" groups="base.group_no_one"/>
                                        <field name="lot_id" column_invisible="0" groups="base.group_no_one"/>
                                        <field name="is_available" column_invisible="0" groups="base.group_no_one"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Finished Move" invisible="0">
                                <field name="finished_move_ids">
                                    <list editable="bottom" delete="0" sample="1" create="0">
                                        <field name="date" readonly="1"/>
                                        <field name="reference" readonly="1"/>
                                        <field name="product_id" readonly="1"/>
                                        <field name="lot_id" string="Serial" readonly="1"/>
                                        <field name="location_id" readonly="1"/>
                                        <field name="location_dest_id" readonly="1"/>
                                        <field name="quantity" readonly="1"/>
                                        <field name="state" readonly="1"/>
                                        <field name="out_tray_id" readonly="state == 'done'" column_invisible="1"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Machine Parameter">
                                <field name="machine_data_ids">
                                    <list editable="bottom" decoration-bf="1" decoration-success="cell_dry_condition == 'good'" decoration-danger="cell_dry_condition == 'fail'">
                                        <field name="date"/>
                                        <field name="temperature"/>
                                        <field name="vacuum"/>
                                        <field name="user_id"/>
                                        <field name="cell_dry_condition" column_invisible="1"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Quality">
                                <field name="quality_ids">
                                    <list editable="bottom">
                                        <field name="date"/>
                                        <field name="moisture_content"/>
                                        <field name="color_shading"/>
                                        <field name="quality_remarks"/>
                                        <field name="visual_examination"/>
                                        <field name="user_id" readonly="1"/>
                                    </list>
                                    <form>
                                        <group>
                                            <group>
                                                <field name="date"/>
                                                <field name="moisture_content"/>
                                                <field name="color_shading"/>
                                            </group>
                                            <group>
                                                <field name="visual_examination"/>
                                                <field name="user_id" readonly="1"/>
                                            </group>
                                        </group>
                                    </form>
                                </field>
                            </page>

                            <page string="Utility">
                                <field name="utility_ids">
                                    <list editable="bottom" decoration-bf="1" decoration-success="cell_drying_utility_condition == 'good'" decoration-danger="cell_drying_utility_condition == 'fail'">
                                        <field name="date"/>
                                        <field name="humidity"/>
                                        <field name="temperature"/>
                                        <field name="compressed_air"/>
                                        <field name="nitrogen"/>
                                        <field name="user_id" readonly="1"/>
                                        <field name="cell_drying_utility_condition" column_invisible="1"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Breakdown">
                                <field name="breakdown_ids">
                                    <list delete="0" readonly="1">
                                        <field name="time" string="Time"/>
                                        <field name="reason" column_invisible="1"/>
                                        <field name="remarks"/>
                                        <field name="root_cause"/>
                                        <field name="action_taken"/>
                                        <field name="end_time"/>
                                    </list>
                                    <form delete="0">
                                        <group>
                                            <group>
                                                <field name="time" string="Time" readonly="1"/>
                                                <field name="remarks" readonly="1"/>
                                                <field name="root_cause"/>
                                                <field name="action_taken"/>
                                                <field name="end_time"/>
                                            </group>
                                            <group></group>
                                        </group>
                                    </form>
                                </field>
                            </page>

                            <page string="Others">
                                <group>
                                    <group>
                                        <field name="type" readonly="state in ('done', 'close')"/>
                                        <field name="location_src_id" readonly="state in ('done', 'close')"/>
                                        <field name="location_dest_id" readonly="state in ('done', 'close')"/>
                                        <field name="production_location_id" readonly="state in ('done', 'close')"/>
                                    </group>
                                    <group></group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>

                    <chatter/>

                </form>
            </field>
        </record>

        <record id="cell_drying_process_list_view" model="ir.ui.view">
            <field name="name">cell.drying.list</field>
            <field name="model">cell.drying</field>
            <field name="arch" type="xml">
                <list string="Cell Drying" sample="1">
                    <field name="name" column_invisible="0"/>
                    <field name="product_id"/>
                    <field name="product_qty"/>
                    <!--                    <field name="qty_produced"/>-->
                    <field name="state"/>
                </list>
            </field>
        </record>


        <record id="cell_drying_process_form_action" model="ir.actions.act_window">
            <field name="name">Cell Drying</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">cell.drying</field>
            <field name="domain">[]</field> <!-- force empty -->
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Cell Drying
                </p>

            </field>
        </record>

        <menuitem id="menu_cell_drying_process" name="Cell Drying" action="cell_drying_process_form_action" parent="fnet_mrp.menu_manufacturing_main" sequence="7"/>


    </data>
</odoo>