<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_inventory_stock_location" model="ir.actions.act_window">
            <field name="name">Stock Quant Tree View</field>
            <field name="res_model">stock.quant</field> <!-- Replace with your actual model name -->
            <field name="view_mode">list,form</field> <!-- You can include other views if needed -->
            <field name="view_id" ref="stock.view_stock_quant_tree_inventory_editable"/> <!-- Replace with your list view's ID -->
            <field name="domain">[]</field> <!-- You can set a domain if needed -->
            <field name="context">{}</field> <!-- Set your default group_by field -->
        </record>

        <record id="product_tray_form_view" model="ir.ui.view">
            <field name="name">product.tray.form</field>
            <field name="model">product.tray</field>
            <field name="priority">100</field>
            <field name="arch" type="xml">
                <form string="Operation">
                    <header>
                        <button type="object" name="open_serial_numbers" string="View Serials"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="number" invisible="0" required="1"/>
                                <!--                                <field name="product_id" required="1"/>-->
                            </group>
                            <group>
                                <field name="tray_type_id" required="1"/>
                                <field name="max_count" string="Max Count"/>

                            </group>
                        </group>
                        <notebook>
                            <page string="Lot Number" name="lot_number">
                                <field name="lot_ids">
                                    <list editable="bottom">
                                        <field name="name" required="1" string="Serial Number"/>
                                        <field name="product_id"/>
                                        <!--                                        <field name="company_id" invisible="1"/>-->
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="product_tray_list_view" model="ir.ui.view">
            <field name="name">product.tray.list</field>
            <field name="model">product.tray</field>
            <field name="arch" type="xml">
                <list string="Product Tray" sample="1" limit="200">
                    <field name="number" column_invisible="0"/>
                    <field name="product_id"/>
                </list>
            </field>
        </record>


        <record id="product_tray_form_action" model="ir.actions.act_window">
            <field name="name">Product tray</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">product.tray</field>
            <field name="domain">[]</field> <!-- force empty -->
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No operation found. Let's create one!
                </p>

            </field>
        </record>


        <record id="product_tray_type_form_view" model="ir.ui.view">
            <field name="name">product.tray.form</field>
            <field name="model">tray.type</field>
            <field name="priority">100</field>
            <field name="arch" type="xml">
                <form string="Tray Type">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" invisible="0" required="1"/>
                            </group>
                            <group>
                                <field name="no_of_product_occupied" required="1" string="Product Count"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="product_tray_type_list_view" model="ir.ui.view">
            <field name="name">product.tray.type.list</field>
            <field name="model">tray.type</field>
            <field name="arch" type="xml">
                <list string="Tray type" sample="1">
                    <field name="name" column_invisible="0"/>
                    <field name="no_of_product_occupied" string="Product Count"/>
                </list>
            </field>
        </record>


        <record id="product_tray_type_form_action" model="ir.actions.act_window">
            <field name="name">Product tray type</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tray.type</field>
            <field name="domain">[]</field> <!-- force empty -->
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No operation found. Let's create one!
                </p>

            </field>
        </record>


        <record id="production_breakdown_form_view1" model="ir.ui.view">
            <field name="name">production.breakdown.form</field>
            <field name="model">production.breakdown</field>
            <field name="arch" type="xml">
                <form string="Scrap">
                    <group>
                        <group>
                            <field name="reason"/>
                        </group>
                        <group></group>
                    </group>
                </form>
            </field>
        </record>

        <record id="production_breakdown_form_view2" model="ir.ui.view">
            <field name="name">production.breakdown.form</field>
            <field name="model">production.breakdown</field>
            <field name="arch" type="xml">
                <form string="Scrap">
                    <group>
                        <group>
                            <field name="reason"/>
                        </group>
                        <group></group>
                    </group>
                    <footer>
                        <button name="action_done_breakdown" string="Confirm" type="object" class="btn-primary" data-hotkey="q"/>
                        <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                    </footer>
                </form>
            </field>
        </record>

        <record model="ir.actions.act_window" id="action_production_breakdown">
            <field name="name">Production Breakdown</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">production.breakdown</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="production_breakdown_form_view1"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Breakdown production
                </p>
            </field>
        </record>


        <record id="product_type_change_duration_form_view" model="ir.ui.view">
            <field name="name">type.change.duration.form</field>
            <field name="model">type.change.duration</field>
            <field name="priority">100</field>
            <field name="arch" type="xml">
                <form string="Type Change">
                    <sheet>
                        <group>
                            <group>
                                <field name="type" invisible="0" required="1"/>

                            </group>
                            <group>
                                <field name="duration" widget="float_time" required="1"/>
                            </group>
                        </group>

                    </sheet>
                </form>
            </field>
        </record>

        <record id="product_type_change_duration_list_view" model="ir.ui.view">
            <field name="name">type.change.duration.list</field>
            <field name="model">type.change.duration</field>
            <field name="arch" type="xml">
                <list string="Type Change" sample="1">
                    <field name="type" column_invisible="0"/>
                    <field name="duration" widget="float_time"/>
                </list>
            </field>
        </record>


        <record id="product_type_change_duration_action" model="ir.actions.act_window">
            <field name="name">Product type change duration</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">type.change.duration</field>
            <field name="domain">[]</field> <!-- force empty -->
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Product Type change duration. Let's create one!
                </p>

            </field>
        </record>


        <record id="product_serial_number_view_form" model="ir.ui.view">
            <field name="name">product.serial.number.view.form</field>
            <field name="model">product.serial.number</field>
            <field name="arch" type="xml">
                <form string="Serial Number">
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="lot_id"/>
                        </group>
                        <group>
                            <field name="product_id"/>
                            <field name="tray_id" invisible="1"/>
                        </group>
                    </group>
                </form>
            </field>
        </record>
        <record id="product_serial_number_view_list" model="ir.ui.view">
            <field name="name">product.serial.number.view.list</field>
            <field name="model">product.serial.number</field>
            <field name="arch" type="xml">
                <list string="Serial Number">
                    <field name="name"/>
                    <field name="product_id"/>
                    <field name="lot_id"/>
                </list>
            </field>
        </record>

        <record id="view_product_template_form_inherit" model="ir.ui.view">
            <field name="name">product.template.form.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                <notebook position="inside">
                    <page string="Manufacturing">
                        <group>
                            <group>
                                <field name="mrp_ok" string="Can be Manufactured"/>
                                <field name="enable_inspection" string="Enable Inspection"/>
                                <field name="default_inspection_template" string="Inspection Template" required="enable_inspection == True" invisible="enable_inspection == False"/>
                            </group>
                            <group></group>
                        </group>
                    </page>
                </notebook>
            </field>
        </record>
        <record id="view_manufacturing_component_form" model="ir.ui.view">
            <field name="name">manufacturing.component.form.view</field>
            <field name="model">manufacturing.component</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="product_id"/>
                                <field name="name"/>
                                <field name="company_id" invisible="1"/>
                                <field name="location_src_id"/>
                                <field name="location_dest_id" invisible="1"/>
                                <field name="lot_id" string="Serial"/>
                                <field name="lot_number" string="Serial Number"/>
                                <field name="lot_ids" widget="many2many_tags" invisible="1"/>
                            </group>
                            <group>
                                <field name="anode_slitting_id" invisible="1"/>
                                <field name="state" invisible="1"/>
                                <field name="available_qty" readonly="1"/>
                                <field name="check_available" invisible="1"/>
                                <field name="stock_availability" invisible="1"/>
                                <field name="product_qty" string="Required Qty"/>
                                <field name="output_same"/>
                                <field name="tray_id" invisible="1"/>
                                <field name="serial_number_id" invisible="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_manufacturing_component_list" model="ir.ui.view">
            <field name="name">manufacturing.component.list</field>
            <field name="model">manufacturing.component</field>
            <field name="arch" type="xml">
                <list editable="bottom" decoration-bf="1" decoration-success="stock_availability == 'ok'" decoration-danger="stock_availability == 'not_ok'">
                    <field name="id"/>
                    <field name="product_id"/>
                    <field name="name"/>
                    <field name="company_id" column_invisible="1"/>
                    <field name="location_src_id"/>
                    <field name="location_dest_id" column_invisible="1"/>
                    <field name="has_tracking" column_invisible="1"/>
                    <!--<field name="lot_id" string="Serial"/>-->
                    <field name="lot_id" invisible="has_tracking == 'none'" required="has_tracking != 'none'" groups="stock.group_production_lot"/>
                    <field name="lot_number" string="Serial Number" column_invisible="1"/>
                    <field name="lot_ids" widget="many2many_tags" column_invisible="1"/>
                    <field name="state" column_invisible="1"/>
                    <field name="available_qty" force_save="1"/>
                    <field name="check_available" column_invisible="1"/>
                    <field name="stock_availability" column_invisible="1"/>
                    <field name="product_qty" string="Required Qty" readonly="has_tracking == 'serial'"/>
                    <field name="product_uom_category_id" column_invisible="1"/>
                    <field name="product_uom_id" options="{'no_open': True, 'no_create': True}"/>
                    <field name="output_same" column_invisible="1"/>
                    <field name="tray_id" column_invisible="1"/>
                    <field name="serial_number_id" column_invisible="1"/>
                    <field name="state" readonly="1" column_invisible="1"/>
                    <!--<button name="remove_manufacturing_component_line" string="Remove" type="object"
                            class="btn-primary"/>-->
                </list>
            </field>
        </record>
        <record id="view_material_line_list" model="ir.ui.view">
            <field name="name">material.line.list</field>
            <field name="model">material.line</field>
            <field name="arch" type="xml">
                <list editable="bottom" decoration-success="product_qty &gt;= qty_done" decoration-danger="qty_done &lt; product_qty">
                    <field name="has_tracking" column_invisible="1"/>
                    <field name="product_uom_category_id" column_invisible="1"/>
                    <field name="product_id"/>
                    <field name="name"/>
                    <field name="location_src_id"/>
                    <field name="product_uom_id"/>
                    <field name="product_qty" string="Required Qty"/>
                    <field name="qty_done" string="Reserved Qty"/>
                    <button name="action_show_details" type="object" icon="fa-list"/>
                </list>
            </field>
        </record>

        <record id="view_material_line_form" model="ir.ui.view">
            <field name="name">material.line.form</field>
            <field name="model">material.line</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="has_tracking" invisible="1"/>
                                <field name="product_uom_category_id" invisible="1"/>
                                <field name="product_id"/>
                                <field name="name"/>
                                <field name="product_uom_id"/>
                                <field name="product_qty"/>
                                <field name="qty_done"/>
                            </group>
                            <group>
                                <field name="location_src_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Components">
                                <group string="Reserve Material" invisible="has_tracking == 'none'">
                                    <label for="production_plan_id" string="Reserve Material by Plan" invisible="out_file != False"/>
                                    <div invisible="out_file != False">
                                        <field name="production_plan_id"/>
                                    </div>
                                    <label for="out_file" string="Reserve Material by File"/>
                                    <div>
                                        <field name="out_file_name" invisible="1"/>
                                        <field name="out_file" filename="out_file_name"/>
                                    </div>
                                    <div>
                                        <button name="action_download_sample" type="object" string="Download Sample File"/>
                                    </div>
                                </group>
                                <group>
                                    <button name="action_upload_serial" type="object" string="Reserve" class="oe_highlight"/>
                                </group>
                                <field name="component_ids" readonly="1"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_product_serial_number_form" model="ir.ui.view">
            <field name="name">product.serial.number.form</field>
            <field name="model">product.serial.number</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="product_id"/>
                            <field name="product_uom_category_id" invisible="1"/>
                            <field name="product_uom_id"/>
                            <field name="lot_id"/>
                            <field name="is_available"/>
                            <field name="tray_id" invisible="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_product_serial_number_list" model="ir.ui.view">
            <field name="name">product.serial.number.list</field>
            <field name="model">product.serial.number</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="product_id"/>
                    <field name="product_uom_category_id" column_invisible="1"/>
                    <field name="product_uom_id"/>
                    <field name="lot_id"/>
                    <field name="is_available"/>
                    <field name="tray_id" column_invisible="1"/>
                </list>
            </field>
        </record>
        <record id="inspection_team_view_form" model="ir.ui.view">
            <field name="name">inspection.team.view.form</field>
            <field name="model">inspection.team</field>
            <field name="arch" type="xml">
                <form string="Team">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="user_ids" widget="many2many_tags"/>
                                <field name="approve_user_ids" widget="many2many_tags"/>
                            </group>
                            <group></group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="inspection_team_view_list" model="ir.ui.view">
            <field name="name">inspection.team.view.list</field>
            <field name="model">inspection.team</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="user_ids" widget="many2many_tags"/>
                    <field name="approve_user_ids" widget="many2many_tags"/>
                </list>
            </field>
        </record>
        <record id="inspection_team_action" model="ir.actions.act_window">
            <field name="name">Inspection Team</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">inspection.team</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create Inspection Team
                </p>
            </field>
        </record>

        <record id="res_config_settings_view_form_purchase_inspection_rev" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.purchase.inspection.rev</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="25"/>
            <field name="inherit_id" ref="purchase_extended.res_config_settings_view_form_purchase_rev"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='revision_details']" position="inside">
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane"></div>
                        <div class="o_setting_right_pane">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="ccr_doc_no" class="col-lg-4 o_light_label"/>
                                    <field name="ccr_doc_no"/>
                                </div>
                                <div class="row mt8">
                                    <label for="ccr_rev_no" class="col-lg-4 o_light_label"/>
                                    <field name="ccr_rev_no"/>
                                </div>
                                <div class="row mt8">
                                    <label for="ccr_rev_date" class="col-lg-4 o_light_label"/>
                                    <field name="ccr_rev_date"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane"></div>
                        <div class="o_setting_right_pane">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="pqc_doc_no" class="col-lg-4 o_light_label"/>
                                    <field name="pqc_doc_no"/>
                                </div>
                                <div class="row mt8">
                                    <label for="pqc_rev_no" class="col-lg-4 o_light_label"/>
                                    <field name="pqc_rev_no"/>
                                </div>
                                <div class="row mt8">
                                    <label for="pqc_rev_date" class="col-lg-4 o_light_label"/>
                                    <field name="pqc_rev_date"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane"></div>
                        <div class="o_setting_right_pane">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="in_ins_doc_no" class="col-lg-4 o_light_label"/>
                                    <field name="in_ins_doc_no"/>
                                </div>
                                <div class="row mt8">
                                    <label for="in_ins_rev_no" class="col-lg-4 o_light_label"/>
                                    <field name="in_ins_rev_no"/>
                                </div>
                                <div class="row mt8">
                                    <label for="in_ins_rev_date" class="col-lg-4 o_light_label"/>
                                    <field name="in_ins_rev_date"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane"></div>
                        <div class="o_setting_right_pane">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="out_ins_doc_no" class="col-lg-4 o_light_label"/>
                                    <field name="out_ins_doc_no"/>
                                </div>
                                <div class="row mt8">
                                    <label for="out_ins_rev_no" class="col-lg-4 o_light_label"/>
                                    <field name="out_ins_rev_no"/>
                                </div>
                                <div class="row mt8">
                                    <label for="out_ins_rev_date" class="col-lg-4 o_light_label"/>
                                    <field name="out_ins_rev_date"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane"></div>
                        <div class="o_setting_right_pane">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="audit_ins_doc_no" class="col-lg-4 o_light_label"/>
                                    <field name="audit_ins_doc_no"/>
                                </div>
                                <div class="row mt8">
                                    <label for="audit_ins_rev_no" class="col-lg-4 o_light_label"/>
                                    <field name="audit_ins_rev_no"/>
                                </div>
                                <div class="row mt8">
                                    <label for="audit_ins_rev_date" class="col-lg-4 o_light_label"/>
                                    <field name="audit_ins_rev_date"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane"></div>
                        <div class="o_setting_right_pane">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="dn_doc_no" class="col-lg-4 o_light_label"/>
                                    <field name="dn_doc_no"/>
                                </div>
                                <div class="row mt8">
                                    <label for="dn_rev_no" class="col-lg-4 o_light_label"/>
                                    <field name="dn_rev_no"/>
                                </div>
                                <div class="row mt8">
                                    <label for="dn_rev_date" class="col-lg-4 o_light_label"/>
                                    <field name="dn_rev_date"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>

        <record id="view_manufacturing_batch_tree" model="ir.ui.view">
            <field name="name">manufacturing.batch.tree</field>
            <field name="model">manufacturing.batch</field>
            <field name="arch" type="xml">
                <list editable="top">
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="action_manufacturing_batch" model="ir.actions.act_window">
            <field name="name">Manufacturing Batch</field>
            <field name="res_model">manufacturing.batch</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
