<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="customer_complaint_register_view" model="ir.ui.view">
            <field name="name">complaint.register.view.form</field>
            <field name="model">complaint.register</field>
            <field name="arch" type="xml">
                <form string="Customer Complaint Register">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" string="Reference"/>
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="customer_id" widget="res_partner_many2one" placeholder="Company Name..." domain="[('is_company', '=', True)]" context="{'default_is_company': True, 'show_vat': True,'show_address': 1}" options='{"always_reload": True, "no_quick_create": True}'/>

                                <field name="product_id"/>
                                <field name="product_model_id"/>
                                <field name="attended_by"/>
                                <field name="received_on"/>
                                <field name="lot_qty"/>
                                <field name="modality"/>
                            </group>
                            <group>
                                <field name="complaint_details"/>
                                <field name="repeated_complain"/>
                                <field name="call_solved"/>
                                <field name="status"/>
                                <field name="remark"/>
                                <field name="completed_on"/>
                                <field name="defect_qty"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Revision Details">
                                <group>
                                    <group>
                                        <field name="doc_no"/>
                                        <field name="date_revision"/>
                                        <field name="no_revision"/>
                                    </group>
                                    <group>

                                    </group>


                                </group>
                            </page>

                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="complaint_register_view_list" model="ir.ui.view">
            <field name="name">complaint.register.list</field>
            <field name="model">complaint.register</field>
            <field name="arch" type="xml">
                <list default_order="received_on desc">
                    <field name="name"/>
                    <field name="customer_id"/>
                    <field name="received_on"/>
                    <field name="product_id"/>
                    <field name="product_model_id"/>
                    <field name="modality"/>
                    <field name="status"/>
                    <field name="call_solved"/>
                </list>
            </field>
        </record>
        <record id="action_customer_complaint_register" model="ir.actions.act_window">
            <field name="name">Customer Complaint Register</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">complaint.register</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create Customer Complaint Register
                </p>
            </field>
        </record>


    </data>
</odoo>