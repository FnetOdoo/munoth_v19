<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <data>
        <!-- Degas-->
        <record id="cell_degas_process_form_view" model="ir.ui.view">
            <field name="name">degas.cell.form</field>
            <field name="model">degas.cell</field>
            <field name="priority">100</field>
            <field name="arch" type="xml">
                <form string="Degas" duplicate="0" delete="0">
                    <header>
                        <!--                        <button name="action_confirm" string="Confirm" type="object" states="draft"-->
                        <!--                                class="oe_highlight"/>-->
                        <button name="action_start" string="Start" type="object" invisible="state != 'draft'" class="oe_highlight"/>
                        <button name="check_available_stock" string="Check Availability" type="object" invisible="state != 'draft'"/>
                        <button name="action_done_production" string="Production Done" class="btn-success" type="object" invisible="state != 'progress'"/>
                        <button name="action_close" string="Close" type="object" invisible="state != 'done'" class="oe_highlight"/>
                        <button name="create_scrap_product" string="Rejection" class="btn-strong" type="object" invisible="state != 'close'"/>

                        <button name="action_break_production" string="Pause Production" class="btn-danger" type="object" invisible="state != 'progress'"/>

                        <button name="action_restart_production" string="Restart Production" class="btn-success" type="object" invisible="state != 'hold'"/>

                        <!--                        <button name="action_request_process_approval" string="Request Process Approval" class="btn-warning" type="object" attrs="{'invisible': [('process_status_degas','=',True)]}"/>-->
                        <!--                        <button name="action_request_inspection" string="Request First Article Inspection" class="btn-warning" type="object" attrs="{'invisible': [('fai_status_degas','=',True)]}"/>-->

                        <field name="state" widget="statusbar" statusbar_visible="draft,progress,done" readonly="1" clickable="1"/>
                    </header>

                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" string="In Process Quality" name="action_view_in_process_quality" type="object" icon="fa-check" invisible="state in ['draft','confirmed','cancel']"/>
                            <button class="oe_stat_button" string="Quality" name="action_view_quality" type="object" icon="fa-check" invisible="state in ['draft']"/>
                            <button class="oe_stat_button" string="Stock Move" name="action_view_product_move" type="object" icon="fa-exchange" invisible="state in ['draft']"/>
                            <button class="oe_stat_button" name="action_aged_formation_record" type="object" icon="fa-arrow-left" invisible="aged_formation_count == 0">
                                <field name="aged_formation_count" widget="statinfo" string="Aged Form Cell"/>
                            </button>
                            <button class="oe_stat_button" name="show_pad_printing_record" type="object" icon="fa-arrow-right" invisible="pad_print_count == 0">
                                <field name="pad_print_count" widget="statinfo" string="Pad Print"/>
                            </button>
                            <button class="oe_stat_button" name="action_open_process_approval" type="object" icon="fa-pencil" invisible="pa_count == 0">
                                <field name="pa_count" widget="statinfo" string="Process Approval"/>
                            </button>
                            <button class="oe_stat_button" name="action_open_inspection" type="object" icon="fa-pencil" invisible="fai_count == 0">
                                <field name="fai_count" widget="statinfo" string="FAI Inspection"/>
                            </button>
                            <button name="action_create_pad_printing_cell" icon="fa-pencil" string="Create Pad Print" type="object" invisible="state != 'close'"/>

                            <button name="action_view_lots" type="object" string="Show Lots" icon="fa-list"/>
                        </div>
                        <div class="oe_title">
                            <label for="name" string="Reference"/>
                            <h1>
                                <field name="name" readonly="1"/>
                                <field name="fai_status_degas" invisible="1"/>
                                <field name="process_status_degas" invisible="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="production_plan_id" invisible="0" required="1" readonly="state != 'draft'"/>
                                <field name="clamp_baking_id" invisible="1" readonly="state != 'draft'"/>
                                <field name="product_model_id" required="1" string="Model" readonly="state != 'draft'"/>
                                <field name="machine_id" required="1" domain="['|', ('type', '=', type), ('type', '=', False)]" readonly="state != 'draft'"/>
                                <field name="operation_id" domain="[('product_model_id', '=', product_model_id),('type', '=', type)]" required="1" readonly="state != 'draft'"/>
                                <field name="product_id" force_save="1" required="0" domain="[('type', 'in', ['product', 'consu']),'|',('company_id', '=', False),('company_id', '=', company_id)]"/>
                                <field name="product_tracking" required="0" invisible="1"/>
                                <field name="product_tmpl_id" invisible="1"/>
                                <field name="product_qty" readonly="state in ('done', 'close')"/>
                                <field name="product_uom_id" invisible="1"/>
                            </group>
                            <group>
                                <!--                                <field name="aged_formation_id"/>-->
                                <field name="bom_id" domain="[('product_id', '=', product_id), ('product_model_id', '=', product_model_id)]" required="0" readonly="state != 'draft'"/>
                                <field name="qty_producing" invisible="1"/>
                                <field name="product_uom_category_id" invisible="1"/>
                                <field name="product_uom_qty" invisible="1"/>
                                <field name="company_id" invisible="1"/>
                                <field name="start_time" readonly="1"/>
                                <label for="expected_end_time" invisible="start_time == False"/>
                                <div invisible="start_time == False">
                                    <field name="expected_end_time" nolabel="1" class="oe_inline"/>
                                    <span invisible="end_time != False">/
                                        <field name="remaining_hours" widget="float_time" nolabel="1" class="oe_inline"/>
                                        Hours Remaining
                                    </span>
                                </div>
                                <field name="end_time" readonly="1"/>
                                <field name="user_id" readonly="1"/>
                                <!--                                <field name="qty_produced"  attrs="{'invisible': [('state', 'in', ['draft', 'confirmed'])] , 'readonly' : [('state', 'in', ['draft', 'confirmed', 'done', 'close'])]}"/>-->
                                <!--                                <field name="product_tray_id" invisible="1"/>-->
                                <!--                                <div class="o_row">-->
                                <!--                                    <button name="action_update_lot_product" attrs="{'invisible' : [('state', '!=', 'draft')]}" string="Update Serial" type="object" class="btn-primary" />-->
                                <!--                                </div>-->
                            </group>
                        </group>

                        <notebook>
                            <page string="Materials" name="input">
                                <field name="input_material_lines" readonly="state in ['done','close']"/>
                            </page>
                            <page string="Detailed Materials" name="materials">
                                <button name="action_remove_line" type="object" invisible="state in ['done','close']"/>
                                <field name="component_ids" readonly="state in ['done','close']"/>
                            </page>
                            <page string="Machine Parameter">
                                <field name="machine_data_ids">
                                    <list>
                                        <field name="sealing_temp"/>
                                        <field name="sealing_pressure"/>
                                        <field name="sealing_time"/>
                                        <field name="vacuum"/>
                                        <field name="vacuum_holding_time"/>
                                        <field name="weight_before_degas"/>
                                        <field name="weight_after_degas"/>
                                        <field name="date"/>
                                        <field name="user_id"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Quality">
                                <field name="quality_ids">
                                    <list editable="bottom">
                                        <field name="date"/>
                                        <field name="voltage"/>
                                        <field name="resistance"/>
                                        <field name="quality_remarks"/>
                                        <field name="visual_examination"/>
                                        <field name="user_id"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Resistance Test">
                                <field name="resistance_ids">
                                    <list editable="bottom">
                                        <field name="voltage"/>
                                        <field name="resistance_set"/>
                                        <field name="resist_time"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Utility">
                                <field name="utility_ids">
                                    <list editable="bottom" decoration-success="clamp_baking_utility_condition == 'good'" decoration-danger="clamp_baking_utility_condition == 'fail'">
                                        <field name="date"/>
                                        <field name="humidity"/>
                                        <field name="temperature"/>
                                        <field name="vacuum_section_pressure"/>
                                        <field name="compressed_air"/>
                                        <field name="nitrogen"/>
                                        <field name="user_id"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Serial Number" invisible="state in ['done','close']">
                                <field name="lot_ids">
                                    <list editable="bottom">
                                        <field name="name"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Finished Move">
                                <field name="finished_move_ids">
                                    <list>
                                        <field name="date"/>
                                        <field name="reference"/>
                                        <field name="product_id"/>
                                        <field name="lot_id"/>
                                        <field name="location_id"/>
                                        <field name="location_dest_id"/>
                                        <field name="quantity"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Breakdown">
                                <field name="breakdown_ids">
                                    <list>
                                        <field name="time"/>
                                        <field name="remarks"/>
                                        <field name="root_cause"/>
                                        <field name="action_taken"/>
                                        <field name="end_time"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Others" readonly="state in ['done','close']">
                                <field name="location_src_id"/>
                                <field name="location_dest_id"/>
                            </page>

                        </notebook>
                    </sheet>

                    <chatter/>
                </form>
            </field>
        </record>
        <record id="cell_degas_process_list_view" model="ir.ui.view">
            <field name="name">degas.cell.list</field>
            <field name="model">degas.cell</field>
            <field name="arch" type="xml">
                <list string="Degas" sample="1">
                    <field name="name" invisible="0"/>
                    <field name="product_id"/>
                    <field name="product_qty"/>
                    <!--                    <field name="qty_produced"/>-->
                    <field name="state"/>
                </list>
            </field>
        </record>


        <record id="cell_degas_process_form_action" model="ir.actions.act_window">
            <field name="name">Degas</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">degas.cell</field>
            <field name="domain">[]</field> <!-- force empty -->
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Degas Cell
                </p>

            </field>
        </record>

        <menuitem id="menu_cell_degas_process" name="Degas" action="cell_degas_process_form_action" parent="fnet_mrp.menu_manufacturing_main" sequence="12"/>


    </data>
</odoo>