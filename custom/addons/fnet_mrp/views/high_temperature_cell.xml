<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <data>
        <!-- HT Cell-->

        <record id="high_temperature_cell_process_form_view" model="ir.ui.view">
            <field name="name">high.temperature.cell.form</field>
            <field name="model">high.temperature.cell</field>
            <field name="priority">100</field>
            <field name="arch" type="xml">
                <form string="HT Cell" duplicate="0" delete="0">
                    <header>
                        <!--                        <button name="action_confirm" string="Confirm" type="object" states="draft"-->
                        <!--                                class="oe_highlight"/>-->
                        <button name="action_start" string="Start" type="object" invisible="state != 'draft'" class="oe_highlight"/>
                        <button name="action_done_production" string="Production Done" class="btn-success" type="object" invisible="state != 'progress'"/>
                        <button name="action_close" string="Close" type="object" invisible="state != 'done'" class="oe_highlight"/>
                        <button name="check_available_stock" string="Check Availability" type="object" invisible="state != 'draft'"/>
                        <!--                        <button name="create_scrap_product" string="Scrap" class="btn-strong" states="done"-->
                        <!--                                type="object"/>-->
                        <button name="action_break_production" string="Pause Production" class="btn-danger" type="object" invisible="state != 'progress'"/>
                        <button name="action_restart_production" string="Restart Production" class="btn-success" type="object" invisible="state != 'hold'"/>
                        <button name="create_scrap_product" string="Rejection" class="btn-strong" type="object" invisible="state != 'close'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,progress,done" readonly="1" clickable="1"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" string="In Process Quality" name="action_view_in_process_quality" type="object" icon="fa-check" invisible="state in ['draft','confirmed','cancel']"/>
                            <!--<button class="oe_stat_button" string="Quality" name="action_view_quality"
                                    type="object"
                                    icon="fa-check" attrs="{'invisible': [('state', 'in', ['draft'])]}"/>-->
                            <button class="oe_stat_button" string="Stock Move" name="action_view_product_move" type="object" icon="fa-exchange" invisible="state in ['draft','confirmed']"/>
                            <button class="oe_stat_button" name="action_cell_injection_record_record" type="object" icon="fa-arrow-left" invisible="cell_injection_count == 0">
                                <field name="cell_injection_count" widget="statinfo" string="Injection Cell"/>
                            </button>
                            <button class="oe_stat_button" name="show_clamp_baking_record" type="object" icon="fa-arrow-right" invisible="clamp_baking_count == 0">
                                <field name="clamp_baking_count" widget="statinfo" string="Clamp Baking"/>
                            </button>

                            <button name="action_create_clamp_baking" icon="fa-pencil" string="Create Clamp Baking" type="object" invisible="state != 'close'"/>
                        </div>
                        <div class="oe_title">
                            <label for="name" string="Reference"/>
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>

                        <group>
                            <group>
                                <field name="production_plan_id" invisible="1" required="1" readonly="state != 'draft'"/>
                                <field name="product_model_id" required="1" string="Model" readonly="state != 'draft'"/>
                                <field name="machine_id" required="1" domain="['|', ('type', '=', type), ('type', '=', False)]" readonly="state != 'draft'"/>
                                <field name="operation_id" domain="[('product_model_id', '=', product_model_id),('type', '=', type)]" required="1" readonly="state != 'draft'"/>
                                <field name="product_id"/>
                                <field name="product_tracking" invisible="1"/>
                                <field name="product_tmpl_id" invisible="1"/>
                                <field name="product_qty" readonly="state in ['done','close']"/>
                                <field name="product_uom_id" invisible="1"/>
                            </group>
                            <group>
                                <!--                                <field name="injection_id"/>-->
                                <field name="bom_id" domain="[('product_id', '=', product_id), ('product_model_id', '=', product_model_id)]" readonly="state != 'draft'"/>
                                <field name="qty_producing" invisible="1"/>
                                <field name="product_uom_category_id" invisible="1"/>
                                <field name="product_uom_qty" invisible="1"/>
                                <field name="company_id" invisible="1"/>
                                <field name="start_time" readonly="1"/>
                                <label for="expected_end_time" invisible="start_time == False"/>
                                <div invisible="start_time == False">
                                    <field name="expected_end_time" nolabel="1" class="oe_inline"/>
                                    <span invisible="end_time != False">
                                        /
                                        <field name="remaining_hours" widget="float_time" nolabel="1" class="oe_inline"/>
                                        Hours Remaining
                                    </span>
                                </div>
                                <field name="end_time" readonly="1"/>
                                <field name="user_id" readonly="1"/>
                                <!--                                <field name="qty_produced"  attrs="{'invisible': [('state', 'in', ['draft', 'confirmed'])] , 'readonly' : [('state', 'in', ['draft', 'confirmed', 'done', 'close'])]}"/>-->
                                <!--                                <field name="product_tray_id" attrs="{'readonly' : [('state', '!=', 'draft')]}"/>-->
                                <!--                                <div class="o_row">-->
                                <!--                                    <button name="action_update_lot_product" attrs="{'invisible' : [('state', '!=', 'draft')]}" string="Update Serial" type="object" class="btn-primary" />-->
                                <!--                                </div>-->
                            </group>
                        </group>
                        <notebook>
                            <page string="Materials">
                                <field name="input_material_lines" readonly="state in ['done','close']"/>
                            </page>
                            <page string="Detailed Materials">
                                <group>
                                    <div>
                                        <button name="action_remove_line" type="object" invisible="state in ['done','close']"/>
                                    </div>
                                </group>
                                <field name="component_ids" readonly="state in ['done','close']"/>
                            </page>

                            <page string="Machine Parameter">
                                <field name="machine_data_ids">
                                    <list>
                                        <field name="date"/>
                                        <field name="injection_volume"/>
                                        <field name="sealing_temp"/>
                                        <field name="sealing_pressure"/>
                                        <field name="vac_sucker"/>
                                        <field name="vac_stewing_1"/>
                                        <field name="vac_stewing_2"/>
                                        <field name="vac_stewing_3"/>
                                        <field name="vac_sealer"/>
                                        <field name="post_injection_stabilization_time"/>
                                        <field name="sealing_width"/>
                                        <field name="weight_before"/>
                                        <field name="weight_after"/>
                                        <field name="user_id"/>
                                        <field name="injection_value_condition" invisible="1"/>
                                    </list>

                                    <form>
                                        <group>
                                            <group>
                                                <field name="date"/>
                                                <field name="injection_volume"/>
                                                <field name="sealing_temp"/>
                                                <field name="sealing_pressure"/>
                                                <field name="vac_sucker"/>
                                                <field name="vac_stewing_1"/>
                                                <field name="vac_stewing_2"/>
                                                <field name="vac_stewing_3"/>
                                            </group>
                                            <group>
                                                <field name="vac_sealer"/>
                                                <field name="post_injection_stabilization_time"/>
                                                <field name="sealing_width"/>
                                                <field name="weight_before"/>
                                                <field name="weight_after"/>
                                                <field name="user_id"/>
                                                <field name="injection_value_condition" invisible="1"/>
                                            </group>
                                        </group>
                                    </form>
                                </field>
                            </page>

                            <page string="Quality">
                                <field name="quality_ids">
                                    <list editable="bottom">
                                        <field name="date"/>
                                        <field name="moisture_in_electrolyte"/>
                                        <field name="weight"/>
                                        <field name="dimension"/>
                                        <field name="quality_remarks"/>
                                        <field name="visual_examination"/>
                                        <field name="user_id" readonly="1"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Utility">
                                <field name="utility_ids">
                                    <list editable="bottom" decoration-success="injection_utility_condition == 'good'" decoration-danger="injection_utility_condition == 'fail'">
                                        <field name="date"/>
                                        <field name="humidity"/>
                                        <field name="temperature"/>
                                        <field name="vacuum_section_pressure"/>
                                        <field name="compressed_air"/>
                                        <field name="nitrogen"/>
                                        <field name="user_id" readonly="1"/>
                                        <field name="injection_utility_condition" column_invisible="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Serial Number" invisible="state in ['done','close']">
                                <button name="get_serial_numbers" type="object" string="Get All Serial"/>
                                <button name="clear_serial_numbers" type="object" string="Clear All Serial"/>
                                <field name="lot_ids" context="{'default_product_id': product_id, 'default_product_uom_id': product_uom_id}">
                                    <list editable="bottom">
                                        <field name="name" required="1" string="Serial Number"/>
                                        <field name="product_id" column_invisible="0" groups="base.group_no_one"/>
                                        <field name="product_uom_category_id" column_invisible="1"/>
                                        <field name="product_uom_id" column_invisible="0" groups="base.group_no_one"/>
                                        <field name="lot_id" column_invisible="0" groups="base.group_no_one"/>
                                        <field name="is_available" column_invisible="0" groups="base.group_no_one"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Finished Move">
                                <group>
                                    <field name="out_tray_id" invisible="1"/>
                                </group>
                                <field name="finished_move_ids">
                                    <list>
                                        <field name="date" readonly="1"/>
                                        <field name="reference" readonly="1"/>
                                        <field name="product_id" readonly="1"/>
                                        <field name="lot_id" readonly="1"/>
                                        <field name="location_id" readonly="1"/>
                                        <field name="location_dest_id" readonly="1"/>
                                        <field name="quantity" readonly="1"/>
                                        <field name="state" readonly="1"/>
                                        <field name="out_tray_id" readonly="state in ['done']" invisible="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Breakdown">
                                <field name="breakdown_ids">
                                    <list>
                                        <field name="time" string="Time"/>
                                        <field name="reason" column_invisible="1"/>
                                        <field name="remarks"/>
                                        <field name="root_cause"/>
                                        <field name="action_taken"/>
                                        <field name="end_time"/>
                                    </list>
                                    <form delete="0">
                                        <group>
                                            <group>
                                                <field name="time" string="Time" readonly="1"/>
                                                <field name="remarks" readonly="1"/>
                                                <field name="root_cause"/>
                                                <field name="action_taken"/>
                                                <field name="end_time"/>
                                            </group>
                                            <group></group>
                                        </group>
                                    </form>
                                </field>
                            </page>

                            <page string="Others">
                                <group>
                                    <group>
                                        <field name="type" readonly="state in ['done','close']"/>
                                        <field name="location_src_id" readonly="state in ['done','close']"/>
                                        <field name="location_dest_id" readonly="state in ['done','close']"/>
                                        <field name="production_location_id" readonly="state in ['done','close']"/>
                                    </group>
                                    <group/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="high_temperature_cell_process_list_view" model="ir.ui.view">
            <field name="name">high.temperature.cell.list</field>
            <field name="model">high.temperature.cell</field>
            <field name="arch" type="xml">
                <list string="HT Cell" sample="1">
                    <field name="name" column_invisible="0"/>
                    <field name="product_id"/>
                    <field name="product_qty"/>
                    <!--                    <field name="qty_produced"/>-->
                    <field name="state"/>
                </list>
            </field>
        </record>


        <record id="high_temperature_cell_process_form_action" model="ir.actions.act_window">
            <field name="name">High Temperature Standing</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">high.temperature.cell</field>
            <field name="domain">[]</field> <!-- force empty -->
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    High Temp Standing
                </p>

            </field>
        </record>

        <menuitem id="menu_high_temperature_cell_process" name="High Temperature Standing" action="high_temperature_cell_process_form_action" parent="fnet_mrp.menu_manufacturing_main" sequence="9"/>


    </data>
</odoo>