<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Bill of Materials -->

        <record id="manufacturing_bom_form_view" model="ir.ui.view">
            <field name="name">manufacturing.bom.form</field>
            <field name="model">manufacturing.bom</field>
            <field name="priority">100</field>
            <field name="arch" type="xml">
                <form string="Bill of Material">
                    <sheet>
                        <group>
                            <group>
                                <!--                                <field name="name" invisible="1"/>-->
                                <field name="product_model_id" string="Model" invisible="type == 'powerbank'" required="type != 'powerbank'"/>
                                <field name="product_id" invisible="0" string="Product"/>
                                <field name="product_uom_id" invisible="0" string="Unit of Measure"/>
                                <field name="product_uom_category_id" invisible="1" string="Product"/>
                                <field name="product_tmpl_id" required="0" invisible="0"/>
                                <field name="product_qty"/>
                            </group>
                            <group>
                                <field name="name"/>
                                <field name="manufacturing_process_type_id" string="Type" invisible="0"/>
                                <!--                                <field name="type_id"/>-->
                                <field name="roll_size" string="Roll Size" invisible="type not in ['anode_slitting', 'cathode_slitting']" required="type in ['anode_slitting', 'cathode_slitting']"/>
                                <field name="quantity" invisible="1"/>
                                <field name="company_id"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Components" name="components">
                                <field name="bom_line_ids">
                                    <list editable="bottom">
                                        <field name="product_id"/>
                                        <field name="company_id" column_invisible="1"/>
                                        <field name="product_uom_category_id" column_invisible="1"/>
                                        <field name="product_uom_id"/>
                                        <field name="product_qty"/>
                                        <field name="output_same"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="manufacturing_bom_tree_view" model="ir.ui.view">
            <field name="name">manufacturing.bom.tree</field>
            <field name="model">manufacturing.bom</field>
            <field name="arch" type="xml">
                <list string="Bill of Materials" sample="1">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="product_tmpl_id"/>
                    <field name="product_model_id" string="Model" required="1"/>
                    <field name="type"/>
                    <field name="product_qty"/>
                </list>
            </field>
        </record>

        <record id="manufacturing_bom_search_view" model="ir.ui.view">
            <field name="name">manufacturing.bom.search</field>
            <field name="model">manufacturing.bom</field>
            <field name="arch" type="xml">
                <search string="BOM">
                    <field name="sequence" widget="handle"/>
                    <!--                    <field name="name" invisible="1"/>-->
                    <field name="product_id"/>
                    <field name="product_model_id" string="Model" required="1"/>
                    <field name="name"/>
                    <group>
                        <filter string="Model" name="product_model_id" domain="[]" context="{'group_by': 'product_model_id'}"/>
                        <filter string="Product" name="product_id" domain="[]" context="{'group_by': 'product_id'}"/>
                    </group>
                </search>
            </field>
        </record>


        <record id="manufacturing_bom_form_action" model="ir.actions.act_window">
            <field name="name">Bills of Materials</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">manufacturing.bom</field>
            <field name="domain">[]</field> <!-- force empty -->
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No bill of materials found. Let's create one!
                </p>
                <p>
                    Bills of materials allow you to define the list of required raw
                    materials used to make a finished product; through a manufacturing
                    order or a pack of products.
                </p>
            </field>
        </record>



    </data>
</odoo>
