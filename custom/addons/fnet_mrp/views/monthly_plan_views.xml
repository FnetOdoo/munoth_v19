<odoo>
    <data>
        <record id="monthly_plan_form_view" model="ir.ui.view">
            <field name="name">monthly.plan.form.view</field>
            <field name="model">monthly.plan</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_confirm" type="object" string="Confirm" class="oe_highlight" invisible="state != 'draft'"/>
                        <button name="action_cancel" type="object" string="Cancel" invisible="state != 'draft'"/>
                        <button name="action_reset" type="object" string="Set to Draft" invisible="state != 'cancel'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,confirm"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" type="object" name="action_view_report" string="View Result" icon="fa-life-ring"/>
                        </div>
                        <div class="oe_title">
                            <label for="name" string="Reference"/>
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <field name="company_id" invisible="1"/>
                        <group>
                            <group>
                                <field name="model_id"/>
                                <field name="stage"/>
                                <field name="resource_calendar_id"/>
                            </group>
                            <group>
                                <field name="date" widget="month_year_picker"/>
                                <field name="user_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Detailed Plan">
                                <field name="line_ids" context="{'default_date': date}" readonly="state != 'draft'"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="monthly_plan_list_view" model="ir.ui.view">
            <field name="name">monthly.plan.list.view</field>
            <field name="model">monthly.plan</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="date"/>
                    <field name="model_id"/>
                    <field name="stage"/>
                    <field name="state"/>
                </list>
            </field>
        </record>
        <record id="monthly_plan_action" model="ir.actions.act_window">
            <field name="name">Monthly Plan</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">monthly.plan</field>
            <field name="domain">[]</field> <!-- force empty -->
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Monthly Plan
                </p>
            </field>
        </record>


        <record id="monthly_plan_line_list_view" model="ir.ui.view">
            <field name="name">monthly.plan.line.list.view</field>
            <field name="model">monthly.plan.line</field>
            <field name="arch" type="xml">
                <list delete="0" create="0">
                    <field name="operation_id" width="0.5" required="1"/>
                    <field name="opening_qty"/>
                    <field name="day_1"/>
                    <field name="day_2"/>
                    <field name="day_3"/>
                    <field name="day_4"/>
                    <field name="day_5"/>
                    <field name="day_6"/>
                    <field name="day_7"/>
                    <field name="day_8"/>
                    <field name="day_9"/>
                    <field name="day_10"/>
                    <field name="day_11"/>
                    <field name="day_12"/>
                    <field name="day_13"/>
                    <field name="day_14"/>
                    <field name="day_15"/>
                    <field name="day_16"/>
                    <field name="day_17"/>
                    <field name="day_18"/>
                    <field name="day_19"/>
                    <field name="day_20"/>
                    <field name="day_21"/>
                    <field name="day_22"/>
                    <field name="day_23"/>
                    <field name="day_24"/>
                    <field name="day_25"/>
                    <field name="day_26"/>
                    <field name="day_27"/>
                    <field name="day_28"/>
                    <field name="day_29"/>
                    <field name="day_30"/>
                    <field name="day_31"/>
                </list>
            </field>
        </record>

        <record id="monthly_plan_line_form_view" model="ir.ui.view">
            <field name="name">monthly.plan.line.form.view</field>
            <field name="model">monthly.plan.line</field>
            <field name="arch" type="xml">
                <form>
                    <div>
                        <field name="date" invisible="1"/>
                        <h4>Production plan for the month of
                            <field name="month" class="oe_inline" readonly="1"/>
                            /
                            <field name="year" class="oe_inline" readonly="1"/>
                            for
                            <field name="operation_id" class="oe_inline" readonly="1"/>
                        </h4>
                    </div>
                    <group col="3">
                        <group>
                            <field name="day_1"/>
                            <field name="day_2"/>
                            <field name="day_3"/>
                            <field name="day_4"/>
                            <field name="day_5"/>
                            <field name="day_6"/>
                            <field name="day_7"/>
                            <field name="day_8"/>
                            <field name="day_9"/>
                            <field name="day_10"/>
                        </group>
                        <group>
                            <field name="day_11"/>
                            <field name="day_12"/>
                            <field name="day_13"/>
                            <field name="day_14"/>
                            <field name="day_15"/>
                            <field name="day_16"/>
                            <field name="day_17"/>
                            <field name="day_18"/>
                            <field name="day_19"/>
                            <field name="day_20"/>
                        </group>
                        <group>
                            <field name="day_21"/>
                            <field name="day_22"/>
                            <field name="day_23"/>
                            <field name="day_24"/>
                            <field name="day_25"/>
                            <field name="day_26"/>
                            <field name="day_27"/>
                            <field name="day_28"/>
                            <field name="day_29"/>
                            <field name="day_30"/>
                            <field name="day_31"/>
                        </group>
                    </group>
                </form>
            </field>
        </record>
        <record id="monthly_plan_result_list_view" model="ir.ui.view">
            <field name="name">monthly.plan.result.list.view</field>
            <field name="model">monthly.plan.result</field>
            <field name="arch" type="xml">
                <list create="0" delete="0">
                    <field name="date"/>
                    <field name="operation_id"/>
                    <field name="planned_qty"/>
                    <field name="produced_qty"/>
                    <field name="rejected_qty"/>
                </list>
            </field>
        </record>
    </data>
</odoo>