<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <data>
        <!-- Injection-->

        <record id="mrp_powerbank_form_view" model="ir.ui.view">
            <field name="name">mrp.powerbank.form.view</field>
            <field name="model">mrp.powerbank</field>
            <field name="arch" type="xml">
                <form string="Power Bank" duplicate="0" delete="0">
                    <header>
                        <button name="action_start" string="Start" type="object" invisible="state != 'draft'" class="oe_highlight"/>
                        <button name="check_available_stock" string="Check Availability" type="object" invisible="state != 'draft'"/>
                        <button name="action_done_production" string="Production Done" class="btn-success" invisible="state != 'progress'" type="object"/>
                        <button name="action_close" string="Close" type="object" invisible="state != 'done'" class="oe_highlight"/>
                        <button name="create_scrap_product" string="Scrap" class="btn-strong" invisible="state != 'close'" type="object"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,progress,done" readonly="1"/>
                    </header>

                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" string="Quality" name="action_view_quality" type="object" icon="fa-check" invisible="state in ['draft','confirmed','progress','done']"/>
                            <button class="oe_stat_button" string="Stock Move" name="action_view_product_move" type="object" icon="fa-exchange" invisible="state in ['draft']"/>
                        </div>
                        <div class="oe_title">
                            <label for="name" string="Reference"/>
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>

                        <group>
                            <group>
                                <field name="operation_id" domain="[('type', '=', 'powerbank')]" readonly="state != 'draft'"/>
                                <field name="product_id" force_save="1"  required="0" domain="[('type', 'in', ['product', 'consu']),'|',('company_id', '=', False),('company_id', '=', company_id)]"/>
                                <field name="product_tracking" required="0" invisible="1"/>
                                <field name="product_tmpl_id" invisible="1"/>
                                <field name="product_qty" readonly="state in ['done', 'close']"/>
                                <field name="product_uom_id" invisible="1"/>
                            </group>
                            <group>
                                <field name="bom_id" domain="[('product_id', '=', product_id)]" invisible="0" readonly="state != 'draft'"/>
                                <field name="product_uom_category_id" invisible="1"/>
                                <field name="company_id" invisible="1"/>
                                <field name="date_start" readonly="1"/>
                                <label for="expected_date_end" invisible="date_start == False"/>
                                <div invisible="date_start == False">
                                    <field name="expected_date_end" nolabel="1" class="oe_inline"/>
                                    <span invisible="date_end != False">/
                                        <field name="remaining_hours" widget="float_time" nolabel="1" class="oe_inline"/>
                                        Hours Remaining
                                    </span>
                                </div>
                                <field name="date_end" readonly="1"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Materials" name="input">
                                <field name="input_material_lines" readonly="state in ['done', 'close']"/>
                            </page>

                            <page string="Detailed Materials" name="materials">
                                <group>
                                    <div>
                                        <button name="action_remove_line" type="object" string="Remove All" invisible="state in ['done', 'close']"/>
                                    </div>
                                </group>
                                <field name="component_ids" readonly="state in ['done', 'close']"/>
                            </page>

                            <page string="Serial Number" invisible="state in ['done', 'close']">
                                <group>
                                    <group string="From Material Tab">
                                        <div>
                                            <button name="get_serial_numbers" type="object" string="Get All Serial"/>
                                            <button name="clear_serial_numbers" type="object" string="Clear All Serial"/>
                                        </div>
                                    </group>
                                    <group string="Upload file">
                                        <div>
                                            <field name="out_file_name" invisible="1"/>
                                            <field name="out_file" filename="out_file_name"/>
                                            <button name="action_upload_serial" type="object" string="Upload Serial"/>
                                            <button name="action_download_sample" type="object" string="Download Sample"/>
                                        </div>
                                    </group>
                                </group>
                                <field name="lot_ids" context="{'default_product_id': product_id, 'default_product_uom_id': product_uom_id}">
                                    <list editable="bottom">
                                        <field name="name" required="1" string="Serial Number"/>
                                        <field name="product_id" column_invisible="0" groups="base.group_no_one"/>
                                        <field name="product_uom_category_id" column_invisible="1"/>
                                        <field name="product_uom_id" column_invisible="0" groups="base.group_no_one"/>
                                        <field name="lot_id" column_invisible="0" groups="base.group_no_one"/>
                                        <field name="is_available" column_invisible="0" groups="base.group_no_one"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Stock Moves" invisible="0">
                                <field name="finished_move_ids">
                                    <list editable="bottom" delete="0" sample="1" create="0">
                                        <field name="date" readonly="1"/>
                                        <field name="reference" readonly="1"/>
                                        <field name="product_id" readonly="1"/>
                                        <field name="lot_id" string="Serial" readonly="1"/>
                                        <field name="location_id" readonly="1"/>
                                        <field name="location_dest_id" readonly="1"/>
                                        <field name="quantity" readonly="1"/>
                                        <field name="state" readonly="1"/>
                                        <field name="out_tray_id" readonly="state == 'done'" column_invisible="1"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Others">
                                <group>
                                    <group>
                                        <field name="type" readonly="state in ['done', 'close']"/>
                                        <field name="location_src_id" readonly="state in ['done', 'close']"/>
                                        <field name="location_dest_id" readonly="state in ['done', 'close']"/>
                                        <field name="production_location_id" readonly="state in ['done', 'close']"/>
                                    </group>
                                    <group>

                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="mrp_powerbank__list_view" model="ir.ui.view">
            <field name="name">mrp.powerbank.form.list</field>
            <field name="model">mrp.powerbank</field>
            <field name="arch" type="xml">
                <list string="Power Bank" sample="1">
                    <field name="name" column_invisible="0"/>
                    <field name="product_id"/>
                    <field name="product_qty"/>
                    <field name="state"/>
                </list>
            </field>
        </record>


        <record id="mrp_powerbank_form_action" model="ir.actions.act_window">
            <field name="name">Power Bank</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">mrp.powerbank</field>
            <field name="domain">[]</field> <!-- force empty -->
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Power Bank
                </p>

            </field>
        </record>



    </data>
</odoo>