<?xml version="1.0" encoding="UTF-8" ?>
<odoo>


    <record id="product_model_form_view" model="ir.ui.view">
        <field name="name">product.model.form</field>
        <field name="model">product.model</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <form string="Plan">
                <header>
                    <button name="action_user_submit" type="object" string="Request" class="oe_highlight" invisible="state == 'draft' or is_design_user != False"/>
                    <button name="action_design_user_submit" type="object" string="Request" class="oe_highlight" invisible="state not in ['draft','user_request']" groups="fnet_mrp.group_cell_design_user"/>
                    <button name="action_approve" type="object" string="Approve" class="oe_highlight" invisible="state != 'design_user_request'" groups="fnet_mrp.group_cell_design_approver"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,design_user_request,approve"/>
                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="name" string="Model Name" invisible="0" required="1"/>
                            <field name="line_number" required="0" invisible="1"/>
                            <field name="product_template_id" readonly="0"/>
                            <field name="product_id" readonly="0"/>
                        </group>
                        <group>
                            <field name="company_id" readonly="1"/>
                            <field name="note"/>
                            <field name="is_design_user" invisible="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Cell Specification">
                            <group>
                                <group>
                                    <field name="nominal_capacity"/>
                                    <field name="nominal_voltage"/>
                                    <field name="typical_capacity"/>
                                    <field name="charge_cut_off_voltage"/>
                                    <field name="discharge_cut_off_voltage"/>
                                    <field name="internal_impedance"/>
                                    <field name="charge_voltage_charge_limit"/>
                                    <field name="shipment_voltage"/>
                                    <field name="standard_discharge"/>
                                    <field name="fast_charge"/>
                                    <field name="fast_discharge"/>
                                    <field name="weight"/>
                                    <field name="cycle"/>
                                    <field name="standard_charge"/>
                                </group>
                                <group>
                                    <field name="nominal_capacity_remark"/>
                                    <field name="nominal_voltage_remark"/>
                                    <field name="typical_capacity_remark"/>
                                    <field name="charge_cut_off_voltage_remark"/>
                                    <field name="discharge_cut_off_voltage_remark"/>
                                    <field name="internal_impedance_remark"/>
                                    <field name="charge_voltage_charge_limit_remark"/>
                                    <field name="shipment_voltage_remark"/>
                                    <field name="standard_discharge_remark"/>
                                    <field name="fast_charge_remark"/>
                                    <field name="fast_discharge_remark"/>
                                    <field name="weight_remark"/>
                                    <field name="cycle_remark"/>
                                    <field name="standard_charge_remark"/>
                                </group>
                            </group>
                            <group string="Standard Charge">
                                <field name="standard_charge_ids">
                                    <list editable="bottom">
                                        <control>
                                            <create name="add_line_control" string="Add a line"/>
                                            <create name="add_section_control" string="Add a section" context="{'default_display_type': 'line_section'}"/>
                                            <create name="add_note_control" string="Add a note" context="{'default_display_type': 'line_note'}"/>
                                        </control>
                                        <field name="temperature"/>
                                        <field name="remark"/>
                                    </list>
                                </field>
                            </group>
                        </page>

                        <page string="BOM">
                            <field name="product_model_bom_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="product_uom_category_id" column_invisible="1"/>
                                    <field name="product_uom_id" string="Unit of Measure"/>
                                    <field name="product_qty" column_invisible="1"/>
                                    <field name="measurement"/>
                                    <field name="weight" readonly="measurement == 'size'"/>
                                    <field name="length" readonly="measurement == 'weight'"/>
                                    <field name="width" readonly="measurement == 'weight'"/>
                                    <field name="thickness" readonly="measurement == 'weight'"/>
                                    <field name="amount_total"/>
                                </list>
                            </field>
                        </page>

                        <page string="Cell Design">
                            <group>
                                <group string="Cathode" name="cathode">
                                    <field name="nmc" string="NMC %"/>
                                    <field name="cathode_conductive_carbon" string="Cathode Conductive Carbon % "/>
                                    <field name="pvdf" string="PVDF %"/>
                                    <field name="cathode_active_material" string="Active material (AM)"/>
                                    <field name="cathode_am_capacity" string="AM Capacity (mAh/g)"/>
                                    <field name="cathode_am" string="AM (g)"/>
                                    <field name="cathode_carbon" string="Carbon (g)"/>
                                    <field name="cathode_binder1" string="Binder 1 (g)"/>
                                    <field name="cathode_binder2" string="Binder 2 (g)"/>
                                    <field name="cathode_length_of_foil" string="Length of the foil (cm)"/>
                                    <field name="cathode_width_of_foil" string="Width of the foil (cm)"/>
                                    <field name="cathode_thickness_of_the_substrate" string="Thickness of the substrate (um)"/>
                                    <field name="cathode_weight_of_the_foil" string="Weight of the foil"/>
                                    <field name="cathode_length_of_coating_side_a" string="Length of coating side A (cm)"/>
                                    <field name="cathode_length_of_coating_side_b" string="Length of coating side B (cm)"/>
                                    <field name="cathode_width_of_coating" string="Width of coating (cm)"/>
                                    <field name="cathode_coating_area" string="Coating area (cm2)"/>
                                    <field name="cathode_thickness_of_the_electrode" string="Thickness of the electrode (um)"/>
                                    <field name="cathode_weight_of_coated_electrode_with_substrate" string="Weight of the coated electrode with substrate (g) "/>
                                    <field name="cathode_weight_of_coated_electrode_without_substrate" string="Weight of the coated electrode without substrate (g) "/>
                                    <field name="cathode_weight_ni_ai_tab" string="Weight of AI and Ni tab (g)"/>
                                    <field name="cathode_loading_single_side" string="Loading single side (mg/cm2)"/>
                                    <field name="cathode_length_of_separator" string="Length of the separator (cm)"/>
                                    <field name="cathode_width_of_separator" string="Width of the separator (cm)"/>
                                    <field name="cathode_n_p_ratio" string="N/P ratio"/>
                                </group>
                                <group string="Anode" name="anode">
                                    <field name="graphite" string="Graphite %"/>
                                    <field name="anode_conductive_carbon" string="Conductive carbon %"/>
                                    <field name="cmc" string="CMC %"/>
                                    <field name="sbr" string="SBR %"/>
                                    <field name="anode_active_material" string="Active material (AM)"/>
                                    <field name="anode_am_capacity" string="AM Capacity (mAh/g)"/>
                                    <field name="anode_am" string="AM (g)"/>
                                    <field name="anode_carbon" string="Carbon (g)"/>
                                    <field name="anode_binder1" string="Binder 1 (g)"/>
                                    <field name="anode_binder2" string="Binder 2 (g)"/>
                                    <field name="anode_length_of_foil" string="Length of the foil (cm)"/>
                                    <field name="anode_width_of_foil" string="Width of the foil (cm)"/>
                                    <field name="anode_thickness_of_the_substrate" string="Thickness of the substrate (um)"/>
                                    <field name="anode_weight_of_the_foil" string="Weight of the foil"/>
                                    <field name="anode_length_of_coating_side_a" string="Length of coating side A (cm)"/>
                                    <field name="anode_length_of_coating_side_b" string="Length of coating side B (cm)"/>
                                    <field name="anode_width_of_coating" string="Width of coating (cm)"/>
                                    <field name="anode_coating_area" string="Coating area (cm2)"/>
                                    <field name="anode_thickness_of_the_electrode" string="Thickness of the electrode (um)"/>
                                    <field name="anode_weight_of_coated_electrode_with_substrate" string="Weight of the coated electrode with substrate (g) "/>
                                    <field name="anode_weight_of_coated_electrode_without_substrate" string="Weight of the coated electrode without substrate (g) "/>
                                    <field name="anode_weight_ni_ai_tab" string="Weight of AI and Ni tab (g)"/>
                                    <field name="anode_loading_single_side" string="Loading single side (mg/cm2)"/>
                                    <field name="anode_length_of_separator" string="Length of the separator (cm)"/>
                                    <field name="anode_width_of_separator" string="Width of the separator (cm)"/>
                                    <field name="anode_n_p_ratio" string="N/P ratio"/>
                                </group>
                            </group>
                        </page>

                        <page string="Machine">
                            <field name="machine_ids">
                                <list editable="bottom">
                                    <field name="type"/>
                                    <field name="mrp_machine_ids" widget="many2many_tags" domain="[('type', '=', type)]"/>
                                </list>
                            </field>
                        </page>

                        <page string="Operation">
                            <field name="operation_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="manufacturing_stages_id" string="Stage"/>
                                    <field name="manufacturing_process_type_id" string="Operation Type"/>
                                    <field name="bom_id"/>
                                    <field name="machine_id" domain="[('manufacturing_process_type_id', '=', manufacturing_process_type_id)]"/>
                                    <field name="allow_lot_create"/>
                                    <field name="location_src_id"/>
                                    <field name="location_dest_id"/>
                                </list>
                            </field>
                        </page>

                        <page string="Quality Parameters">
                            <group string="Final Inspection">
                                <label for="fai_dimension"/>
                                <div class="o_row">
                                    <field name="fai_dimension" force_save="1" nolabel="1"/>
                                    <span>mm</span>
                                </div>
                                <label for="fai_cutoff_voltage"/>
                                <div class="o_row">
                                    <field name="fai_cutoff_voltage" force_save="1" nolabel="1"/>
                                    <span>V</span>
                                </div>
                                <label for="fai_ir"/>
                                <div class="o_row">
                                    <field name="fai_ir" force_save="1" nolabel="1"/>
                                    <span>mΩ</span>
                                </div>
                                <field name="fai_visual_check"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="product_model_list_view" model="ir.ui.view">
        <field name="name">product.model.list</field>
        <field name="model">product.model</field>
        <field name="arch" type="xml">
            <list string="Product Model" sample="1">
                <field name="name" string="Model Name"/>
                <field name="line_number" column_invisible="1"/>
                <field name="nominal_capacity" string="Capacity" required="0" column_invisible="0"/>
                <field name="note"/>
            </list>
        </field>
    </record>


    <record id="product_model_form_action" model="ir.actions.act_window">
        <field name="name">Product Model</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">product.model</field>
        <field name="domain">[]</field> <!-- force empty -->
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Product Model
            </p>

        </field>
    </record>


</odoo>