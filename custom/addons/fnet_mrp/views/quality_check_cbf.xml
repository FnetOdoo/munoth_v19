<odoo>
    <data>
        <record id="view_quality_check_cbf_form" model="ir.ui.view">
            <field name="name">quality.check.cbf.form</field>
            <field name="model">quality.check.cbf</field>
            <field name="arch" type="xml">
                <form string="Quality Check -Clamb Baking Formation">
                    <sheet>
                        <div>
                            <div style="float:left;">
                                <img src="/web/binary/company_logo" style="height:68px;"/>

                            </div>

                            <h1 style="text-align:center;">
                                <b><span>Process Quality Check Sheet (PQC) - CBF</span></b>
                                <div style="float:right;">
                                    <b style="font-size:13px;">Document:</b><field name="doc_no" style="text-align:right;width:50px;font-size:13px;"/><br/>
                                    <b style="font-size:13px;width:20px;padding-left:17px;">Date:</b><field name="date" style="text-align:right;width:50px;font-size:13px;padding-left:22px;"/>
                                </div>
                            </h1>
                        </div>
                        <br/>
                        <hr/>
                        <group col="6">
                            <field name="model_id"/>
                            <field name="product_id"/>
                        </group>
                        <hr/>
                        <table>
                            <thead>
                                <th>
                                    <th style="width:5%;text-align:center;"></th>
                                    <th style="width:5%;text-align:center;"></th>
                                    <th  style="width:9%;text-align:center;"> CV-Charging Voltage (V)</th>
                                     <th  style="width:6%;text-align:center;"> DV-Discharging Voltage (V)</th>
                                     <th  style="width:6%;text-align:center;">HT-Temperature (C)</th>
                                     <th  style="width:6%;text-align:center;">HP-Pressure (kgf)</th>
                                    <th  style="width:6%;text-align:center;">OCV (V)</th>
                                     <th  style="width:6%;text-align:center;">Remarks</th>

                                </th>
                            </thead>
                            <tbody>
                                <field name="pcq_cdf_ids" style="width:99%;">
                                    <list editable="bottom" string="value">
                                        <field name="date_from" style="width:30%;"/>

                                         <field name="sample_qty"/>
                                        <field name="cbf_cv_actual"/>
                                        <field name="cbf_cv_observation"/>
                                        <field name="cbf_dv_actual"/>
                                        <field name="cbf_dv_observation"/>
                                        <field name="cbf_heating_temperature_actual"/>
                                        <field name="cbf_heating_temperature_observation"/>
                                        <field name="cbf_heating_pressure_actual"/>
                                        <field name="cbf_heating_pressure_observation"/>
                                        <field name="cbf_ocv_actual"/>
                                        <field name="cbf_ocv_observation"/>
                                        <field name="ht_cbf_remarks"/>
                                    </list>
                                </field>

                            </tbody>
                        </table>
                        <div>
                            <div style="float:left;width:50%;text-align:center;">
                                <strong>checked By</strong>
                            </div>
                            <div style="float:right;width:50%;text-align:center;">
                                <strong> Verified By </strong>
                            </div>
                        </div>


                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_quality_check_process_list" model="ir.ui.view">
            <field name="name">quality.check.injection.list.view</field>
            <field name="model">quality.check.injection</field>
            <field name="arch" type="xml">
                <list>
                    <field name="date"/>
                    <field name="model_id"/>
                    <field name="product_id"/>
                </list>
            </field>
        </record>

        <record id="view_process_quality_check_cbf" model="ir.actions.act_window">
            <field name="name">Quality Check in Cbf</field>
            <field name="res_model">quality.check.cbf</field>
            <field name="domain">[]</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Quality Check Process
                </p>
            </field>
        </record>

        <menuitem id="menu_quality_check_cbf" name="Process Quality Check CBF" parent="fnet_mrp.menu_mrp_quality"
                  sequence="3" action="view_process_quality_check_cbf"/>

    </data>
</odoo>