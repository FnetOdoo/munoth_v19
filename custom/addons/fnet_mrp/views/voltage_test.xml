<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <data>
        <!-- Voltage Test-->
        <record id="voltage_test_process_form_view" model="ir.ui.view">
            <field name="name">voltage.test.form</field>
            <field name="model">voltage.test</field>
            <field name="priority">100</field>
            <field name="arch" type="xml">
                <form string="Voltage Test" duplicate="0" delete="0">
                    <header>
                        <!--                        <button name="action_confirm" string="Confirm" type="object" states="draft"
                                                        class="oe_highlight"/>-->
                        <button name="action_start" string="Start" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                        <button name="action_done_production" string="Production Done" class="btn-success" type="object" invisible="state != 'progress'"/>
                        <button name="action_close" string="Close" type="object" class="oe_highlight" invisible="state != 'done'"/>
                        <button name="check_available_stock" string="Check Availability" type="object" invisible="state != 'draft'"/>
                        <button name="create_scrap_product" string="Rejection" class="btn-strong" type="object" invisible="state != 'close'"/>
                        <button name="action_break_production" string="Pause Production" class="btn-danger" type="object" invisible="state != 'progress'"/>
                        <button name="action_restart_production" string="Restart Production" class="btn-success" type="object" invisible="state != 'hold'"/>
                        <!--                        <button name="action_request_process_approval" string="Request Process Approval"  class="btn-warning" type="object" attrs="{'invisible': [('process_status_voltage','=',True)]}"/>-->
                        <!--                        <button name="action_request_inspection" string="Request First Article Inspection"  class="btn-warning" type="object" attrs="{'invisible': [('fai_status_voltage','=',True)]}"/>-->
                        <field name="state" widget="statusbar" statusbar_visible="draft,progress,done" readonly="1" clickable="1"/>
                    </header>

                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" string="In Process Quality" name="action_view_in_process_quality" type="object" icon="fa-check" invisible="state in ['draft','confirmed','cancel']"/>
                            <button class="oe_stat_button" string="Quality" name="action_view_quality" type="object" icon="fa-check" invisible="state == 'draft'"/>
                            <button class="oe_stat_button" string="Stock Move" name="action_view_product_move" type="object" icon="fa-exchange" invisible="state == 'draft'"/>
                            <button class="oe_stat_button" name="action_capacity_record" type="object" icon="fa-arrow-left" invisible="capacity_test_count == 0 or type != 'voltage_test'">
                                <field name="capacity_test_count" widget="statinfo" string="Capacity Test"/>
                            </button>
                            <button class="oe_stat_button" name="show_aged_formation_record" type="object" icon="fa-arrow-right" invisible="aged_formation_count == 0">
                                <field name="aged_formation_count" widget="statinfo" string="Aged Formation"/>
                            </button>
                            <button name="action_create_aged_formation_cell" icon="fa-pencil" string="Aged Formation" type="object" invisible="state != 'done' or type != 'voltage_test' or choose_stage == 'stage_3'"/>
                            <button class="oe_stat_button" name="show_aged_formation_2_record" type="object" icon="fa-arrow-left" invisible="aged_formation_2_count == 0 or type != 'voltage_test_2'">
                                <field name="aged_formation_2_count" widget="statinfo" string="Aged Formation 2"/>
                            </button>
                            <button class="oe_stat_button" name="show_package_record" type="object" icon="fa-arrow-right" invisible="packing_count == 0 or type != 'voltage_test_2'">
                                <field name="packing_count" widget="statinfo" string="Package"/>
                            </button>
                            <button class="oe_stat_button" name="action_open_process_approval" type="object" icon="fa-pencil" invisible="pa_count == 0">
                                <field name="pa_count" widget="statinfo" string="Process Approval"/>
                            </button>
                            <button class="oe_stat_button" name="action_open_inspection" type="object" icon="fa-pencil" invisible="fai_count == 0">
                                <field name="fai_count" widget="statinfo" string="FAI Inspection"/>
                            </button>
                            <button class="oe_stat_button" name="show_capacity_test_record" type="object" icon="fa-arrow-right" invisible="capacity_test_count_1 == 0">
                                <field name="capacity_test_count_1" widget="statinfo" string="Capacity Test"/>
                            </button>
                            <button name="action_create_capacity_test_cell" icon="fa-pencil" string="Create Capacity Test" type="object" invisible="choose_stage not in ['stage_2','stage_3'] or state != 'close'"/>
                            <button name="action_create_package_move_cell" icon="fa-pencil" string="Create Package" type="object" invisible="state != 'done' or type != 'voltage_test_2'"/>
                            <button name="action_view_lots" type="object" string="Show Lots" icon="fa-list"/>
                        </div>
                        <div class="oe_title">
                            <label for="name" string="Reference"/>
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="production_plan_id" invisible="1"/>
                                <field name="pad_printing_id" invisible="1"/>
                                <field name="choose_stage" invisible="1"/>
                                <field name="product_model_id" required="1"/>
                                <field name="machine_id" required="1" domain="['|', ('type', '=', type), ('type', '=', False)]"/>
                                <field name="operation_id" domain="[('product_model_id', '=', product_model_id),('type', '=', type)]"/>
                                <field name="product_id"/>
                                <field name="product_tracking" invisible="1"/>
                                <field name="product_tmpl_id" invisible="1"/>
                                <field name="product_qty" readonly="state in ['done','close']"/>
                                <field name="product_uom_id" invisible="1"/>
                                <field name="fai_status_voltage" invisible="1"/>
                                <field name="process_status_voltage" invisible="1"/>
                            </group>
                            <group>
                                <field name="aged_formation_id"/>
                                <field name="bom_id" domain="[('product_id', '=', product_id), ('product_model_id', '=', product_model_id)]"/>
                                <field name="qty_producing" invisible="1"/>
                                <field name="product_uom_category_id" invisible="1"/>
                                <field name="product_uom_qty" invisible="1"/>
                                <field name="company_id" invisible="1"/>
                                <field name="start_time" readonly="1"/>
                                <label for="expected_end_time" invisible="not start_time"/>
                                <div invisible="not start_time">
                                    <field name="expected_end_time" nolabel="1" class="oe_inline"/>
                                    <span invisible="end_time">
                                        /
                                        <field name="remaining_hours" widget="float_time" nolabel="1" class="oe_inline"/>
                                        Hours Remaining
                                    </span>
                                </div>
                                <field name="end_time" readonly="1"/>
                                <field name="user_id" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Materials">
                                <field name="input_material_lines" readonly="state in ['done','close']"/>
                            </page>
                            <page string="Detailed Materials">
                                <group>
                                    <div>
                                        <button name="action_remove_line" type="object" string="Remove All" invisible="state in ['done','close']"/>
                                    </div>
                                </group>
                                <field name="component_ids" readonly="state in ['done','close']"/>
                            </page>
                            <page string="Machine Parameter">
                                <field name="machine_data_ids">
                                    <list editable="bottom">
                                        <field name="date"/>
                                        <field name="voltage"/>
                                        <field name="resistance"/>
                                        <field name="user_id"/>
                                        <field name="clamp_baking_value_condition" column_invisible="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Quality">
                                <field name="quality_ids">
                                    <list editable="bottom">
                                        <field name="date"/>
                                        <field name="ocv"/>
                                        <field name="ir"/>
                                        <field name="quality_remarks"/>
                                        <field name="visual_examination"/>
                                        <field name="user_id" readonly="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Utility">
                                <field name="utility_ids">
                                    <list editable="bottom" decoration-bf="1" decoration-success="clamp_baking_utility_condition == 'good'" decoration-danger="clamp_baking_utility_condition == 'fail'">
                                        <field name="date"/>
                                        <field name="humidity"/>
                                        <field name="temperature"/>
                                        <field name="vacuum_section_pressure"/>
                                        <field name="compressed_air"/>
                                        <field name="nitrogen"/>
                                        <field name="user_id" readonly="1"/>
                                        <field name="clamp_baking_utility_condition" column_invisible="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Serial Number" invisible="state in ['done', 'close']">
                                <button name="get_serial_numbers" type="object" string="Get All Serial"/>
                                <button name="clear_serial_numbers" type="object" string="Clear All Serial"/>
                                <field name="lot_ids" context="{'default_product_id': product_id, 'default_product_uom_id': product_uom_id}">
                                    <list editable="bottom">
                                        <field name="name" required="1" string="Serial Number"/>
                                        <field name="product_id" invisible="0" groups="base.group_no_one"/>
                                        <field name="product_uom_category_id" invisible="1"/>
                                        <field name="product_uom_id" invisible="0" groups="base.group_no_one"/>
                                        <field name="lot_id" invisible="0" groups="base.group_no_one"/>
                                        <field name="is_available" invisible="0" groups="base.group_no_one"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Finished Move" invisible="0">
                                <group>
                                    <field name="out_tray_id" readonly="state != 'done'" invisible="1"/>
                                </group>
                                <field name="finished_move_ids">
                                    <list editable="bottom" delete="0" sample="1" create="0">
                                        <field name="date" readonly="1"/>
                                        <field name="reference" readonly="1"/>
                                        <field name="product_id" readonly="1"/>
                                        <field name="lot_id" readonly="1"/>
                                        <field name="location_id" readonly="1"/>
                                        <field name="location_dest_id" readonly="1"/>
                                        <field name="quantity" readonly="1"/>
                                        <field name="state" readonly="1"/>
                                        <field name="out_tray_id" readonly="state == 'done'" column_invisible="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Breakdown">
                                <field name="breakdown_ids">
                                    <list delete="0">
                                        <field name="time" string="Time"/>
                                        <field name="reason" column_invisible="1"/>
                                        <field name="remarks"/>
                                        <field name="root_cause"/>
                                        <field name="action_taken"/>
                                        <field name="end_time"/>
                                    </list>

                                    <form delete="0">
                                        <group>
                                            <group>
                                                <field name="time" string="Time" readonly="1"/>
                                                <field name="remarks" readonly="1"/>
                                                <field name="root_cause"/>
                                                <field name="action_taken"/>
                                                <field name="end_time"/>
                                            </group>
                                            <group></group>
                                        </group>
                                    </form>
                                </field>
                            </page>
                            <page string="Others">
                                <group>
                                    <group>
                                        <field name="type" readonly="state in ('done', 'close')"/>
                                        <field name="location_src_id" readonly="state in ('done', 'close')"/>
                                        <field name="location_dest_id" readonly="state in ('done', 'close')"/>
                                        <field name="production_location_id" readonly="state in ('done', 'close')"/>
                                    </group>
                                    <group>

                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
        <record id="voltage_test_process_list_view" model="ir.ui.view">
            <field name="name">voltage.test.list</field>
            <field name="model">voltage.test</field>
            <field name="arch" type="xml">
                <list string="Voltage Test" sample="1">
                    <field name="name" column_invisible="0"/>
                    <field name="product_id"/>
                    <field name="product_qty"/>
                    <!--                    <field name="qty_produced"/>-->
                    <field name="state"/>
                </list>
            </field>
        </record>


        <record id="voltage_test_process_form_action" model="ir.actions.act_window">
            <field name="name">Voltage Test 1</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">voltage.test</field>
            <field name="domain">[('type', '=', 'voltage_test')]</field> <!-- force empty -->
            <field name="context">{'default_type': 'voltage_test'}</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Voltage Test
                </p>

            </field>
        </record>

        <menuitem id="menu_voltage_test_1_process" name="OCV/IR 1" action="voltage_test_process_form_action" parent="fnet_mrp.menu_manufacturing_main" sequence="16"/>


        <record id="voltage_test_2_process_form_action" model="ir.actions.act_window">
            <field name="name">Voltage Test 2</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">voltage.test</field>
            <field name="domain">[('type', '=', 'voltage_test_2')]</field> <!-- force empty -->
            <field name="context">{'default_type': 'voltage_test_2'}</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Voltage Test
                </p>

            </field>
        </record>

        <menuitem id="menu_voltage_test_2_process" name="OCV/IR 2" action="voltage_test_2_process_form_action" parent="fnet_mrp.menu_manufacturing_main" sequence="18"/>


    </data>
</odoo>