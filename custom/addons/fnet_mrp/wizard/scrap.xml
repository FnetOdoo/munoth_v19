<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="manufacturing_scrap_form_view2" model="ir.ui.view">
        <field name="name">manufacturing.scrap.form</field>
        <field name="model">manufacturing.scrap</field>
        <field name="arch" type="xml">
            <form string="Scrap">
                <group>
                    <group>
                        <field name="production_plan_id" options="{'no_create': True}" readonly="1"/>
                        <field name="operation_id" options="{'no_create': True}"  readonly="1"/>
                        <field name="product_id" options="{'no_create': True}"  readonly="1"/>
                        <field name="product_uom_id"  readonly="1"/>
                        <field name="scrap_qty"  readonly="1"/>
                        <field name="product_uom_category_id"  invisible="1"/>
                        <field name="location_src_id"  readonly="1"/>
                    </group>
                    <group>
                        <field name="mrp_lot_ids" widget="many2many_tags" groups="base.group_no_one" invisible="1"/>
                        <field name="lot_file_name" invisible="1"/>
                        <field name="lot_file" filename="lot_file_name" invisible="1"/>
<!--                        <button name="action_upload_serial" class="oe_highlight" type="object" string="Upload Serial"/>-->
                        <field name="lot_ids" widget="many2many_tags" domain="[('id', 'in', mrp_lot_ids), ('final_location_id', '=', location_src_id)]" options="{'no_create': True}"/>
<!--                        <field name="lot_id" domain="[('id', 'in', mrp_lot_ids)]"/>-->
                        <field name="company_id" invisible="1"/>
                        <field name="location_reject_id" required="1" readonly="1"/>
                        <field name="reason"/>
                    </group>
                </group>
                <footer>
                    <button name="action_create_scrap_product" string="Request" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <record model="ir.actions.act_window" id="action_manufacturing_stock_scrap_in_production">
            <field name="name">Scrap Orders</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">manufacturing.scrap</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="manufacturing_scrap_form_view2"/>
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                Scrap products
              </p><p>
                Scrapping a product will remove it from your stock. The product will
                end up in a scrap location that can be used for reporting purpose.
              </p>
            </field>
    </record>


