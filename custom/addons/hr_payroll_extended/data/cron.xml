<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
        MIGRATION NOTE (v15 → v19) — cron.xml
        ───────────────────────────────────────
        hr.contract does NOT exist in v19 community registry.
        Method _contract_expiry() moved to hr.employee.
        Cron targets hr.model_hr_employee instead of hr_contract.model_hr_contract.
        -->
        <record id="ir_cron_auto_contract_expiry" model="ir.cron">
            <field name="name">Contract End Date Automatic Expiry</field>
            <!-- hr.contract removed in v19 community — method moved to hr.employee -->
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="state">code</field>
            <field name="code">model._contract_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
