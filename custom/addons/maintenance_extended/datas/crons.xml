<odoo>
    <data>
        <record id="maintenance_request_alert_cron" model="ir.cron">
            <field name="name">Maintenance Request Alert</field>
            <field name="model_id" ref="model_maintenance_request"/>
            <field name="state">code</field>
            <field name="code">model._cron_maintenance_alert()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>