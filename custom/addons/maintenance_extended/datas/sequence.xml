<odoo>
    <data noupdate="1">
        <record id="sequence_work_order" model="ir.sequence">
            <field name="name">Work Order</field>
            <field name="code">work.order</field>
            <field name="prefix">WO/%(year)s/</field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="sequence_engineering_change_request" model="ir.sequence">
            <field name="name">Engineering Change Request</field>
            <field name="code">engineering.change.request</field>
            <field name="prefix">PFD/QC/ENGG/</field>
            <field name="padding">2</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>