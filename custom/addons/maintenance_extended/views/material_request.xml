<odoo>
    <data>
        <record id="maintenance_material_request_view_form" model="ir.ui.view">
            <field name="name">maintenance.material.request.form</field>
            <field name="model">maintenance.material.request</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button string="Request" name="action_request" type="object" invisible="state != 'draft'" class="oe_highlight"/>
                        <button string="Cancel" name="action_cancel" type="object" invisible="state != 'draft'"/>
                        <button string="Approve" name="action_approve" type="object" invisible="state != 'request'" class="oe_highlight"/>
                        <button string="Refuse" name="action_refuse" type="object" invisible="state != 'request'"/>
                        <button string="Validate" name="action_validate" type="object" invisible="state != 'approve'" class="oe_highlight"/>
                        <button string="Close" name="action_close" type="object" invisible="state != 'receive'" class="oe_highlight"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,request,approve,receive"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_open_pickings" class="oe_stat_button" icon="fa-truck" type="object" invisible="picking_count == 0">
                                <field name="picking_count" widget="statinfo" string="Transfer"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" string="Name"/>
                            </h1>
                        </div>
                        <field name="company_id" invisible="1"/>
                        <group>
                            <group>
                                <field name="employee_id"/>
                                <field name="department_id"/>
                                <field name="responsible_id"/>
                            </group>
                            <group>
                                <field name="request_date"/>
                                <field name="order_id"/>
                                <field name="equipment_id"/>
                                <field name="is_consumed"/>
                                <!--                                <field name="date_end"/>-->
                                <!--                                <field name="date_done"/>-->
                            </group>
                        </group>
                        <notebook>
                            <page string="Materials">
                                <field name="line_ids">
                                    <list editable="bottom">
                                        <field name="company_id" column_invisible="1"/>
                                        <field name="product_uom_category_id" column_invisible="1"/>
                                        <field name="product_id"/>
                                        <field name="name"/>
                                        <field name="product_uom_id"/>
                                        <field name="product_qty"/>
                                    </list>
                                    <form>
                                        <group>
                                            <group>
                                                <field name="company_id" invisible="1"/>
                                                <field name="product_uom_category_id" invisible="1"/>
                                                <field name="name"/>
                                                <field name="product_id"/>
                                            </group>
                                            <group>
                                                <field name="product_uom_id"/>
                                                <field name="product_qty"/>
                                            </group>
                                        </group>
                                    </form>
                                </field>
                            </page>
                            <page name="others" string="Others">
                                <group>
                                    <group>
                                        <field name="picking_type_id"/>
                                        <field name="location_id"/>
                                        <field name="temporary_location"/>
                                        <field name="dest_location_id"/>
                                    </group>
                                    <group></group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
        <record id="maintenance_material_request_view_list" model="ir.ui.view">
            <field name="name">maintenance.material.request.list</field>
            <field name="model">maintenance.material.request</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="employee_id"/>
                    <field name="department_id"/>
                    <field name="request_date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record model="ir.actions.act_window" id="action_maintenance_material_request">
            <field name="name">Material Request</field>
            <field name="res_model">maintenance.material.request</field>
            <field name="view_mode">list,form</field>
        </record>

<!--        <menuitem id="menu_maintenance_material_request" name="Material Request" parent="maintenance.menu_m_request" action="action_maintenance_material_request"/>-->

<!--        <menuitem id="menu_maintenance_material_request_new" name="Maintenance Request" parent="mrp_material_request.menuitem_mrp_material_request_main" action="action_maintenance_material_request"/>-->

    </data>
</odoo>