<odoo>
    <data>
        <record id="maintenance_work_order_view_form" model="ir.ui.view">
            <field name="name">maintenance.work.order.form</field>
            <field name="model">work.order</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button string="Start" name="action_start" type="object" invisible="state != 'draft'" class="btn-success"/>
                        <button string="Create Material Request" name="action_material_request" type="object" class="btn-warning" invisible="not material_ids or material_request_count > 0"/>
                        <button string="Finish" name="action_finish" type="object" invisible="state != 'progress'" class="oe_highlight"/>
                        <button string="Cancel" name="action_cancel" type="object" invisible="state != 'draft'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_open_material_request" class="oe_stat_button" icon="fa-truck" type="object" invisible="material_request_count == 0">
                                <field name="material_request_count" widget="statinfo" string="Material Request"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <label for="number"/>
                            <h1>
                                <field name="number" string="Reference"/>
                            </h1>
                        </div>
                        <field name="company_id" invisible="1"/>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="user_id"/>
                                <field name="date_start"/>
                                <field name="date_end"/>
                            </group>
                            <group>
                                <field name="checklist_id"/>
                                <field name="maintenance_id"/>
                                <field name="equipment_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Materials">
                                <field name="material_ids">
                                    <list editable="top">
                                        <field name="product_id"/>
                                        <field name="product_uom_category_id" column_invisible="1"/>
                                        <field name="product_uom_id"/>
                                        <field name="product_qty"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
        <record id="maintenance_work_order_view_list" model="ir.ui.view">
            <field name="name">maintenance.work.order.list</field>
            <field name="model">work.order</field>
            <field name="arch" type="xml">
                <list>
                    <field name="number"/>
                    <field name="name"/>
                    <field name="user_id"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record model="ir.actions.act_window" id="action_maintenance_work_order">
            <field name="name">WorkOrder</field>
            <field name="res_model">work.order</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_maintenance_work_order" name="Work Order" parent="maintenance.menu_m_request" action="action_maintenance_work_order"/>

    </data>
</odoo>