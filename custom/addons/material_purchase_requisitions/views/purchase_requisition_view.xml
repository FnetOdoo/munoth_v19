<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="material_purchase_requisition_form_view" model="ir.ui.view">
            <field name="name">material.purchase.requisition.form.view</field>
            <field name="model">material.purchase.requisition</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_item_code_creation_request" type="object"
                                string="Item Code Creation Request"
                                class="btn-primary"
                                invisible="item_code_request_sent or not product_creation_line_ids or not is_employee_login"/>

                        <button name="action_product_creation_done" type="object" string="Product Creation Done"
                                class="btn-primary"
                                groups="material_purchase_requisitions.group_purchase_requisition_purchase"
                                invisible="not item_code_request_sent or item_code_creation_done"/>

                        <button name="requisition_confirm" type="object" string="Create Purchase Requisition"
                                invisible="state != 'product_creation_done' or not is_employee_login"
                                class="btn-primary"
                                groups="base.group_user"/>

                        <button name="manager_approve" type="object" string="Manager Approve" class="btn-primary"
                                groups="material_purchase_requisitions.group_purchase_requisition_department,material_purchase_requisitions.group_purchase_requisition_department_and_factory_manager"
                                invisible="state != 'requested' or not is_manager_login"/>

                        <button name="action_factory_manager_approve" type="object" string="Factory Manager Approve"
                                invisible="state != 'dept_manager_approved'" class="btn-primary"
                                groups="material_purchase_requisitions.group_purchase_requisition_manager,material_purchase_requisitions.group_purchase_requisition_department_and_factory_manager"/>

                        <button name="create_po" type="object" string="Create PO"
                                invisible="state != 'factory_manager_approved'" class="btn-primary"
                                groups="material_purchase_requisitions.group_purchase_requisition_purchase"/>

                        <button name="create_transfer" type="object" string="Create Transfer"
                                invisible="state != 'receive' or is_transfer_created" class="btn-primary"
                                groups="material_purchase_requisitions.group_purchase_requisition_store"/>

                        <button name="requisition_reject" type="object" string="Reject"
                                invisible="state not in ('requested','dept_manager_approved','factory_manager_approved')"
                                groups="material_purchase_requisitions.group_purchase_requisition_department,material_purchase_requisitions.group_purchase_requisition_manager,material_purchase_requisitions.group_purchase_requisition_purchase,material_purchase_requisitions.group_purchase_requisition_department_and_factory_manager"/>

                        <!--                        <button name="action_cancel" type="object" string="Cancel"-->
                        <!--                                invisible="state != 'draft'" groups="base.group_user"/>-->

                        <!--                        <button name="reset_draft" type="object" string="Reset to Draft"-->
                        <!--                                invisible="state not in ('cancel','reject','receive')" class="btn-primary"/>-->

                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,product_creation_done,dept_manager_approved,factory_manager_approved,po_created,receive"/>
                    </header>

                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" type="object" icon="fa-truck"
                                    name="show_picking" string="Internal Picking"
                                    groups="material_purchase_requisitions.group_purchase_requisition_store"/>
                            <button class="oe_stat_button" type="object" icon="fa-book"
                                    name="action_show_po" string="Purchase Order"
                                    groups="material_purchase_requisitions.group_purchase_requisition_purchase"/>
                        </div>

                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                                <br/>
                            </h1>
                        </div>

                        <group>
                            <group>
                                <field name="is_employee_login" invisible="1"/>
                                <field name="employee_id" readonly="1"/>
                                <field name="department_id" readonly="state != 'draft'"/>
                                <field name="is_manager_login" invisible="1"/>
                                <field name="company_id" invisible="1"/>
                                <field name="is_transfer_created" invisible="1"/>
                            </group>

                            <group>
                                <field name="request_date" readonly="1"/>
                                <field name="receive_date" readonly="1"/>
                                <!--                                <field name="analytic_account_id"-->
                                <!--                                       groups="analytic.group_analytic_accounting"-->
                                <!--                                       readonly="state in ('reject','cancel','receive')"/>-->
                            </group>
                        </group>

                        <notebook>

                            <page string="Item Code Creation">
                                <field name="product_creation_line_ids"
                                       readonly="state not in ('draft')">
                                    <list editable="bottom">
                                        <field name="product_id" column_invisible="1"/>
                                        <field name="product_name" readonly="parent.state != 'draft'"/>
                                        <field name="specification" readonly="parent.state != 'draft'"/>
                                        <field name="qty" readonly="parent.state != 'draft'"/>
                                        <field name="uom" readonly="parent.state != 'draft'"/>
                                        <field name="remarks" readonly="parent.state != 'draft'"/>
                                        <field name="item_code_created" widget="boolean_toggle" readonly="1"/>
                                        <button name="action_create_product" type="object" string="Create Product"
                                                icon="fa-plus" invisible="product_id"
                                                groups="material_purchase_requisitions.group_purchase_requisition_purchase"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Requisitions Lines">
                                <field name="requisition_line_ids"
                                       readonly="state in ('po_created','cancel','receive','done','cancel','reject')">
                                    <list editable="bottom">
                                        <control>
                                            <create name="add_product_control" string="Add a product"
                                                    invisible="1"/>
                                        </control>
                                        <field name="product_id" readonly="1"/>
                                        <field name="description" readonly="1"/>
                                        <field name="qty" readonly="1"/>
                                        <field name="uom" readonly="1"/>
                                        <field name="partner_id"
                                               groups="material_purchase_requisitions.group_purchase_requisition_purchase"
                                               readonly="parent.state not in  ['factory_manager_approved']"
                                               widget="many2many_tags"/>
                                    </list>
                                </field>
                                <group>
                                    <field name="reason"
                                           readonly="state in ('reject','cancel','receive','done')"
                                           placeholder="Add Reason for Internal Requistion ...."/>
                                </group>
                            </page>
                            <page string="Picking Details">
                                <group>
                                    <group>
                                        <field name="location_id"
                                               groups="material_purchase_requisitions.group_purchase_requisition_user,material_purchase_requisitions.group_purchase_requisition_store"
                                               readonly="state != 'draft'"/>
                                        <field name="dest_location_id"
                                               groups="material_purchase_requisitions.group_purchase_requisition_user,material_purchase_requisitions.group_purchase_requisition_store"
                                               readonly="state != 'draft'"/>
                                        <field name="custom_picking_type_id"
                                               groups="material_purchase_requisitions.group_purchase_requisition_user,material_purchase_requisitions.group_purchase_requisition_store"
                                               readonly="state != 'draft'"/>
                                    </group>
                                </group>
                            </page>

                            <page string="Other Information">
                                <group>
                                    <group>
                                        <!--                                        <field name="dept_manager_id"/>-->
                                        <!--                                        <field name="factory_manager_id" string="Factory Manager Approve"/>-->
                                        <field name="reject_employee_id"/>
                                    </group>
                                    <group>
                                        <!--                                        <field name="managerapp_date"/>-->
                                        <!--                                        <field name="confirm_date"/>-->
                                        <field name="userreject_date"/>
                                    </group>
                                </group>
                                <group>
                                    <field name="reject_reason"
                                           readonly="state in ('reject','cancel','receive')"
                                           placeholder="Please Type a Reason for Reject ...."/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>

                    <chatter/>
                </form>
            </field>
        </record>

        <record id="material_purchase_requisition_list_view" model="ir.ui.view">
            <field name="name">material.purchase.requisition.view.list</field>
            <field name="model">material.purchase.requisition</field>
            <field name="arch" type="xml">
                <list >
                    <field name="name"/>
                    <field name="employee_id"/>
                    <field name="department_id"/>
                    <field name="request_date"/>
                    <field name="date_end"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="state" widget="badge" decoration-muted="state == 'draft'"
                      decoration-info="state in ('product_creation_request','product_creation_done','po_created')"
                      decoration-warning="state in ('requested','dept_manager_approved','factory_manager_approved','partial_receive')"
                      decoration-success="state in ('receive','done')"
                      decoration-danger="state in ('cancel','reject')"/>
                </list>
            </field>
        </record>

        <record id="material_purchase_requisition_search_view" model="ir.ui.view">
            <field name="name">material.purchase.requisition search</field>
            <field name="model">material.purchase.requisition</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="employee_id"/>
                    <field name="request_date"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="date_end"/>
                    <field name="department_id"/>
                    <field name="dept_manager_id"/>
                    <field name="approve_employee_id"/>
                    <field name="location_id"/>
                    <field name="managerapp_date"/>
                    <field name="userrapp_date"/>
                    <field name="receive_date"/>
                    <field name="date_done"/>
                    <field name="dest_location_id"/>
                    <field name="delivery_picking_id"/>
                    <field name="reason"/>
                    <field name="state"/>
                    <group>
                        <filter string="Employee" name="employee_id" context="{'group_by':'employee_id'}"/>
                        <filter string="Requisition Date" name="request_date" context="{'group_by':'request_date'}"/>
                        <filter string="Company" name="company" context="{'group_by':'company_id'}"
                                groups="base.group_multi_company"/>
                        <filter string="Requisition Dedline" name="date_end" context="{'group_by':'date_end'}"/>
                        <filter string="Department" name="department" context="{'group_by':'department_id'}"/>
                        <filter string="Department Manager" name="department_manager"
                                context="{'group_by':'dept_manager_id'}"/>
                        <filter string="Approve By" name="approve_by" context="{'group_by':'approve_employee_id'}"/>
                        <filter string="Location" name="location" context="{'group_by':'location_id'}"/>
                        <filter string="Manager Approve Date" name="managerapp_date"
                                context="{'group_by':'managerapp_date'}"/>
                        <filter string="User Approve Date" name="userapp_date" context="{'group_by':'userrapp_date'}"/>
                        <filter string="Destination Location" name="dest_location_id"
                                context="{'group_by':'dest_location_id'}"/>
                        <filter string="Delivery Picking" name="delivery_picking_id"
                                context="{'group_by':'delivery_picking_id'}"/>
                        <filter string="Reason" name="reason" context="{'group_by':'reason'}"/>
                        <filter string="Date Done" name="date_done" context="{'group_by':'date_done'}"/>
                        <filter string="State" name="state" context="{'group_by':'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="action_material_purchase_requisition">
            <field name="name">Purchase Requisitions</field>
            <field name="res_model">material.purchase.requisition</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_purchase_requisition" name="Purchase Requisitions"
                  groups="material_purchase_requisitions.group_purchase_requisition_user"
                  web_icon="material_purchase_requisitions,static/description/icon.png"/>
        <menuitem id="menu_action_purchase_requisition" name="Purchase Requisitions" parent="menu_purchase_requisition"
                  action="action_material_purchase_requisition"/>

    </data>
</odoo>
