<?xml version="1.0" encoding="utf-8"?>
<odoo>
<!--    <data noupdate="1">-->
        <!-- Material Request Category -->
        <record id="module_category_material_request" model="ir.module.category">
            <field name="name">Material Request</field>
            <field name="description">Material request from department will be approved by these roles.</field>
            <field name="sequence">7</field>
        </record>
        <!-- Material Request Privilege -->
        <record id="privilege_material_request" model="res.groups.privilege">
            <field name="name">Material Request</field>
            <field name="sequence">7</field>
            <field name="category_id" ref="module_category_material_request"/>
        </record>
        <!-- User: PO Creator -->
        <record id="group_material_request_purchase_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="privilege_material_request"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
        <record id="group_material_request_store_user" model="res.groups">
            <field name="name">Store User</field>
            <field name="privilege_id" ref="privilege_material_request"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
        <!-- Manager: First Level Approver -->
        <record id="group_material_request_po_manager" model="res.groups">
            <field name="name">Purchase</field>
            <field name="privilege_id" ref="privilege_material_request"/>
            <field name="implied_ids" eval="[(4, ref('group_material_request_purchase_user'))]"/>
        </record>
        <!-- Manager: First Level Approver -->
        <record id="group_material_request_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="privilege_material_request"/>
            <field name="implied_ids" eval="[(4, ref('group_material_request_purchase_user'))]"/>
        </record>
        <!-- Administrator: Full Access including Purchase -->
        <record id="group_material_request_administrator" model="res.groups">
            <field name="name">Administrator</field>
            <field name="privilege_id" ref="privilege_material_request"/>
            <field name="implied_ids" eval="[
                (4, ref('group_material_request_manager')),
                (4, ref('group_material_request_store_user')),
                (4, ref('group_material_request_po_manager'))
            ]"/>
        </record>
<!--    </data>-->
</odoo>