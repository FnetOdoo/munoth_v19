<odoo>
    <data>
        <record id="view_mrp_material_request_form" model="ir.ui.view">
            <field name="name">view.mrp.material.request.form</field>
            <field name="model">mrp.material.request</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_request" type="object" string="Request" invisible="state != 'draft'"
                                class="oe_highlight"/>
                        <button name="action_manager_approve" type="object"
                                groups="mrp_material_request.group_material_request_manager" string="Manager Approve"
                                invisible="not show_approve_button"
                                class="oe_highlight"/>                        <!--<button name="action_create_delivery" groups="mrp_material_request.group_material_request_purchase_user" type="object" string="Create Delivery" class="oe_highlight" invisible="picking_count > 0 or state in ['draft', 'request']"/>-->
                        <button name="check_available_stock"
                                groups="mrp_material_request.group_material_request_store_user" type="object"
                                string="Check Availability" class="oe_highlight"
                                invisible="state not in ['manager_approve'] or is_delivery_created"/>
                        <button name="action_purchase_manager_request"
                                groups="mrp_material_request.group_material_request_store_user" type="object"
                                string="Request for Purchase"
                                invisible="state not in ['manager_approve'] or not is_none_qty"/>
                        <!--                        <button name="action_material_accept" type="object" string="Create Transfer"-->
                        <!--                                class="oe_highlight" groups="mrp_material_request.group_material_request_store_user"-->
                        <!--                                invisible="state not in ['manager_approve'] or not is_product_available or picking_count &gt; 0"/>-->
                        <!--                        <button name="action_request_purchase_and_transfer" type="object"-->
                        <!--                                string="Purchase Request &amp; Create Partial Transfer" class="oe_highlight"-->
                        <!--                                invisible="not is_mixed_availability or state not in ['manager_approve']"/>-->
                        <button name="action_raise_po"
                                 groups="mrp_material_request.group_material_request_po_manager" type="object"
                                string="Purchase Approve &amp; Create PO" invisible="state != 'purchase_request'"
                                class="oe_highlight"/>
                        <button name="action_purchase_reject"
                                 groups="mrp_material_request.group_material_request_po_manager" type="object"
                                string="Purchase Reject" invisible="state != 'purchase_request'"/>

                        <!--                        <button name="action_check_location_availability" type="object" string="Check Availability"-->
                        <!--                                class="oe_highlight"-->
                        <!--                                invisible="state not in ['received'] or show_remaining_transfer"-->
                        <!--                                groups="mrp_material_request.group_material_request_store_user"/>-->
                        <!--                        <button name="action_create_remaining_transfer" type="object" string="Create Transfer"-->
                        <!--                                class="oe_highlight"-->
                        <!--                                invisible="state not in ['received'] or not show_remaining_transfer or not is_product_available or is_delivery_created"-->
                        <!--                                groups="mrp_material_request.group_material_request_store_user"/>-->
                        <button name="action_reject" groups="mrp_material_request.group_material_request_manager"
                                type="object" string="Reject"
                                invisible="state != 'request' or not show_approve_button"/>
                        <!--<button name="action_confirm" groups="stock.group_stock_manager" type="object" string="Confirm" invisible="state != 'purchase_approve'" class="oe_highlight"/>-->
                        <!--                        <button name="action_raise_po" invisible="state != 'purchase_approve'" groups="mrp_material_request.group_material_request_purchase_user" type="object" string="Raise PO"/>-->
                        <!--<button name="action_check_available" type="object" string="Check Avaliability" invisible="state != 'manager_approve' or check_product == True" class="oe_highlight"/>-->
                        <!--                        <button name="action_done" groups="stock.group_stock_manager" type="object" string="Close" invisible="state != 'material_accept'" class="oe_highlight"/>-->
                        <!--                        <button name="action_cancel" type="object" string="Cancel" invisible="state not in ['request', 'confirm']"/>-->
                        <button name="action_set_to_draft" type="object" string="Set to Draft"
                                invisible="state != 'cancel'"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,request,manager_approve,material_accept"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <!--<button class="oe_stat_button" string="Stock Move" name="action_view_stock_move"
                                        type="object"
                                        icon="fa-exchange" />-->
                            <button class="oe_stat_button" name="action_view_picking" type="object"
                                    invisible="picking_count == 0" icon="fa-truck" groups="mrp_material_request.group_material_request_store_user">
                                <field name="picking_count" widget="statinfo" string="Internal Transfer"/>
                            </button>
                            <button class="oe_stat_button" name="action_view_po" type="object" invisible="po_count == 0"
                                    icon="fa-truck"  groups="mrp_material_request.group_material_request_po_manager">
                                <field name="po_count" widget="statinfo" string="Purchase Order/RFQ"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <label for="name" string="Reference"/>
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="company_id" invisible="1"/>
                                <field name="check_product" invisible="1"/>
                                <field name="purchase_boolean" invisible="1"/>
                                <field name="is_none_qty" invisible="1"/>
                                <field name="show_remaining_transfer" invisible="1"/>
                                <field name="show_approve_button" invisible="1"/>
                                <field name="is_product_available" invisible="1"/>
                                <field name="user_id" required="1" readonly="state not in ('draft',)"
                                       options="{'no_create': True}"/>
                                <field name="department_id" required="1" readonly="state not in ('draft',)"
                                       options="{'no_create': True}"/>
                                <field name="sub_department_id" string="Sub Department"
                                       readonly="state not in ('draft',)" options="{'no_create': True}"/>
                                <field name="type" readonly="state not in ('draft',)"/>
                                <field name="is_mixed_availability" invisible="1"/>
                                <field name="product_available_location"
                                       invisible="state not in ['received', 'confirm']"
                                       domain="[('stock_location', '=', True)]" options="{'no_create': True}"/>

                            </group>
                            <group>
                                <field name="date" readonly="state not in ('draft',)"/>
                                <field name="date_issued" readonly="1" force_save="1"/>
                                <field name="responsible_user_id" readonly="state not in ('draft',)"
                                       options="{'no_create': True}"/>
                                <field name="is_consumed" readonly="state not in ('draft',)"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="material" string="Material Lines">
                                <field name="request_line_ids" widget="section_and_note_one2many" mode="list,kanban"
                                       context="{'default_state': 'draft'}" readonly="state in ('material_accept')">
                                    <list string="Purchase Order Lines" editable="bottom"
                                          decoration-warning="parent.is_mixed_availability == True"
                                          decoration-success="parent.is_product_available == True"
                                          decoration-danger="line_state == 'unavailable'"
                                    >
                                        <control>
                                            <create name="add_product_control" string="Add a product"
                                                    invisible="parent.state != 'draft'"/>
                                            <create name="add_section_control" string="Add a section"
                                                    context="{'default_display_type': 'line_section'}"
                                                    invisible="parent.state != 'draft'"/>
                                            <create name="add_note_control" string="Add a note"
                                                    context="{'default_display_type': 'line_note'}"
                                                    invisible="parent.state != 'draft'"/>
                                        </control>
                                        <field name="company_id" column_invisible="1"/>
                                        <field name="display_type" column_invisible="1"/>
                                        <field name="product_id" required="display_type == False"
                                               readonly="parent.state not in ('draft', 'cancel')"
                                               context="{'quantity': quantity, 'uom': product_uom, 'company_id': parent.company_id}"
                                               force_save="1"
                                               domain="['|', ('company_id', '=', False), ('company_id', '=', parent.company_id)]"/>
                                        <field name="name" widget="section_and_note_text"
                                               readonly="parent.state not in ('draft', 'cancel')"/>
                                        <field name="model_make" readonly="parent.state not in ('draft', 'cancel')"/>
                                        <field name="quantity" readonly="parent.state not in ('draft', 'cancel')"/>
                                        <field name="product_uom" string="UoM"
                                               readonly="parent.state not in ('draft', 'cancel') or line_state == 'done'"
                                               required="display_type == False" force_save="1" optional="show"/>
                                        <field name="purpose" readonly="parent.state not in ('draft', 'cancel')"/>
                                        <field name="remark"/>
                                        <field name="transfer_qty" column_invisible="1"/>
                                        <field name="is_transfer_complete" column_invisible="1"/>
                                        <field name="purchase_qty" readonly="1"
                                                column_invisible="not parent.is_transfer_complete"
                                               groups="purchase.group_purchase_manager"/>
                                        <field name="state" column_invisible="1"/>
                                        <field name="line_state" column_invisible="1"/>
                                        <field name="vendor_id"
                                               groups="purchase.group_purchase_manager"
                                               readonly="parent.state not in ('draft', 'purchase_request') or line_state == 'done' or is_transfer_complete"/>
                                        <field name="check_available" column_invisible="1"/>
                                    </list>
                                </field>
                            </page>

                            <page name="others" string="Others">
                                <group>
                                    <group string="Stock Details">
                                        <field name="picking_type_id" required="state == 'manager_approve'"
                                               readonly="state != 'draft'"/>
                                        <field name="location_id" required="state == 'manager_approve'"
                                               readonly="state != 'draft'"/>
                                        <field name="location_dest_id" required="state == 'manager_approve'"
                                               readonly="state != 'draft'"/>
                                    </group>
                                </group>
                                <group>
                                    <group string="Manager Rejection">
                                        <field name="reject_user_id" readonly="1"/>
                                        <field name="reject_reason"
                                               readonly="state in ('confirm','done','material_accept','material_reject','cancel','reject')"/>
                                    </group>
                                    <group string="Purchase Rejection">
                                        <field name="po_reject_user_id" readonly="1"/>
                                        <field name="purchase_reject_reason"
                                               readonly="state in ('confirm','done','material_accept','material_reject','cancel','reject')"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Approval Line" invisible="1">
                                <group>
                                    <field name="approval_line_ids" readonly="">
                                        <list>
                                            <field name="user_id"/>
                                            <field name="is_email_sent"/>
                                        </list>
                                    </field>

                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
        <record id="view_mrp_material_request_list" model="ir.ui.view">
            <field name="name">view.mrp.material.request.list</field>
            <field name="model">mrp.material.request</field>
            <field name="arch" type="xml">
                <list decoration-info="state == 'draft'" decoration-success="state == 'confirm'"
                      decoration-danger="state == 'cancel'">
                    <field name="name"/>
                    <field name="date"/>
                    <field name="user_id"/>
                    <field name="section"/>
                    <field name="department_id"/>
                    <field name="state"/>
                </list>
            </field>
        </record>
        <record id="view_mrp_material_request_search" model="ir.ui.view">
            <field name="name">view.mrp.material.request.search</field>
            <field name="model">mrp.material.request</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                </search>
            </field>
        </record>
        <record id="action_mrp_material_request" model="ir.actions.act_window">
            <field name="name">Material Request</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">mrp.material.request</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No operation found. Let's create one!
                </p>
            </field>
        </record>

        <menuitem id="menu_mrp_material_request" name="Material Request" parent="menu_manufacturing_request_root"
                  action="action_mrp_material_request" sequence="1"/>

        <menuitem id="menuitem_mrp_material_request" name="Material Requests" parent="stock.menu_stock_warehouse_mgmt"
                  action="action_mrp_material_request" sequence="30"/>

        <record id="action_mrp_material_request_main" model="ir.actions.act_window">
            <field name="name">Material Request</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">mrp.material.request</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'group_by': 'department_id','default_type':'in_ward'}</field>
            <field name="domain">[("type","ilike","in_ward")]</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No operation found. Let's create one!
                </p>
            </field>
        </record>
        <record id="action_mrp_material_return_main" model="ir.actions.act_window">
            <field name="name">Material Return</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">mrp.material.request</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'default_type':'out_ward'}</field>
            <field name="domain">[("type","ilike",'out_ward')]</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No operation found. Let's create one!
                </p>
            </field>
        </record>

        <record id="view_material_request_sub_department_tree" model="ir.ui.view">
            <field name="name">material.request.configuration.tree</field>
            <field name="model">material.request.configuration</field>
            <field name="arch" type="xml">
                <list editable="top">
                    <field name="name"/>
                    <field name="department_id"/>
                    <field name="approval_line_id" string="Approval Line"/>
                    <field name="location_id" string="Source Location"/>
                    <field name="location_dest_id" string="Destination Location"/>
                </list>
            </field>
        </record>
        <record id="view_material_request_is_approval_line_configuration_tree" model="ir.ui.view">
            <field name="name">material.request.configuration.tree</field>
            <field name="model">material.request.configuration</field>
            <field name="arch" type="xml">
                <list editable="top">
                    <field name="name"/>
                    <field name="active" widget="boolean_toggle"/>
                    <field name="user_ids" string="User Ids" widget="many2many_tags"/>
                </list>
            </field>
        </record>
        <record id="action_material_request_is_approval_line_configuration" model="ir.actions.act_window">
            <field name="name">Material Request Configuration</field>
            <field name="res_model">material.request.configuration</field>
            <field name="view_id" ref="view_material_request_is_approval_line_configuration_tree"/>
            <field name="view_mode">list</field>
            <field name="domain">[('is_approval_line', '=', True)]</field>
            <field name="context">{'default_is_approval_line': True}</field>
        </record>

        <record id="action_material_request_is_sub_department_configuration" model="ir.actions.act_window">
            <field name="name">Material Request Configuration</field>
            <field name="res_model">material.request.configuration</field>
            <field name="view_id" ref="view_material_request_sub_department_tree"/>
            <field name="view_mode">list</field>
            <field name="domain">[('is_sub_department', '=', True)]</field>
            <field name="context">{'default_is_sub_department': True}</field>
        </record>


        <menuitem id="menuitem_mrp_material_request_main" name="Material Requests"
                  web_icon="mrp_material_request,static/description/icon.png" groups="mrp_material_request.group_material_request_purchase_user,mrp_material_request.group_material_request_store_user,mrp_material_request.group_material_request_store_user,mrp_material_request.group_material_request_manager"/>
        <menuitem id="menuitem_mrp_material_request_request" name="Material Requests"
                  parent="menuitem_mrp_material_request_main" action="action_mrp_material_request_main" sequence="1"/>
        <menuitem id="menu_material_return" name="Material Returns" parent="menuitem_mrp_material_request_main"
                  action="action_mrp_material_return_main" sequence="2"/>
        <menuitem id="menu_mrp_material_request_configuration"
                  groups="mrp_material_request.group_material_request_administrator" name="Configuration"
                  parent="menuitem_mrp_material_request_main" sequence="100"/>
        <menuitem id="menu_material_request_sub_department" name="Sub Departments"
                  parent="menu_mrp_material_request_configuration"
                  action="action_material_request_is_sub_department_configuration" sequence="1"/>
        <menuitem id="menu_material_request_approval_line" name="Approval Line"
                  parent="menu_mrp_material_request_configuration"
                  action="action_material_request_is_approval_line_configuration" sequence="2"/>
    </data>
</odoo>