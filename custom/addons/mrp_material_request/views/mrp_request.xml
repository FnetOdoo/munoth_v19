<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <menuitem id="menu_manufacturing_request_root" name="Requests" parent="fnet_mrp.menu_manufacturing_root"
              sequence="-100"/>

    <record id="manufacturing_request_form_view" model="ir.ui.view">
        <field name="name">mrp.request.form</field>
        <field name="model">mrp.request</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <form string="Plan">
                <header>
                    <button name="action_confirm" string="Confirm" groups="fnet_mrp.group_manufacturing_manager"
                            type="object" invisible="state != 'submit'" class="oe_highlight"/>
                    <button name="action_submit" string="Submit" type="object" invisible="state != 'draft'"
                            class="oe_highlight"/>
                    <button name="action_cancel" groups="fnet_mrp.group_manufacturing_manager" string="Cancel"
                            type="object" invisible="state != 'submit'" class="oe_highlight"/>
                    <button name="action_draft" string="Draft" type="object" invisible="state != 'close'"
                            class="oe_highlight"/>
                    <button name="action_close" string="Close" type="object" invisible="state != 'done'"
                            class="oe_highlight"/>
                    <button name="action_create_mrp_order" groups="fnet_mrp.group_manufacturing_manager"
                            string="Create Mrp" type="object" invisible="state != 'confirmed'" class="oe_highlight"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,close" readonly="1"
                           clickable="1"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_stock_picking" icon="fa-paste" string="Delivery" type="object"
                                invisible="picking_id == False" class="oe_highlight"/>
                        <button name="action_view_mrp_production" icon="fa-building" type="object"
                                class="oe_stat_button" invisible="production_plan_count == 0">
                            <field name="production_plan_count" widget="statinfo" string="Production"/>
                        </button>
                    </div>

                    <widget name="web_ribbon" title="From Store" bg_color="bg-success" invisible="from_stock == False"/>
                    <widget name="web_ribbon" title="From Delivery" bg_color="bg-success"
                            invisible="from_stock != False"/>

                    <div class="oe_title">
                        <label for="name" string="Reference"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_id" invisible="1"/>
                            <field name="user_id"/>
                            <field name="section"/>
                            <field name="department_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="responsible_user_id"/>
                            <field name="origin"/>
                            <field name="picking_id" invisible="1"/>
                            <field name="from_stock" invisible="1"/>
                            <field name="location_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Request Material">
                            <field name="request_ids">
                                <list editable="bottom">
                                    <field name="product_id" domain="[('mrp_ok', '=', True)]"/>
                                    <field name="product_uom_id"/>
                                    <!--                                    <field name="product_uom_category_id" invisible="1"/>-->
                                    <field name="company_id" column_invisible="1"/>
                                    <field name="product_qty"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="mrp_request_list_view" model="ir.ui.view">
        <field name="name">mrp.request.list</field>
        <field name="model">mrp.request</field>
        <field name="arch" type="xml">
            <list sample="1">
                <field name="name"/>
                <field name="create_date"/>
                <field name="picking_id"/>
                <field name="user_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="mrp_request_search_view" model="ir.ui.view">
        <field name="name">mrp.request.search</field>
        <field name="model">mrp.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
            </search>
        </field>
    </record>


    <record id="action_mrp_request_form_action" model="ir.actions.act_window">
        <field name="name">Manufacturing Request</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">mrp.request</field>
        <field name="domain">[]</field> <!-- force empty -->
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No operation found. Let's create one!
            </p>
        </field>
    </record>

    <menuitem id="menu_manufacturing_request" name="MRP Request" parent="menu_manufacturing_request_root"
              action="action_mrp_request_form_action" sequence="-100"/>


    <record id="action_mrp_stock_request_form_action" model="ir.actions.act_window">
        <field name="name">Manufacturing Request</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">mrp.request</field>
        <field name="domain">[]</field> <!-- force empty -->
        <field name="view_mode">list,form</field>
        <field name="context">{'default_from_stock': True}
        </field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No operation found. Let's create one!
            </p>

        </field>
    </record>
    <menuitem id="menuitem_manufacturing_reqeust" name="Manufacturing Request" parent="stock.menu_stock_warehouse_mgmt"
              action="action_mrp_stock_request_form_action" sequence="30"/>

</odoo>