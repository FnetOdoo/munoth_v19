<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <record id="anode_slitting_process_form_view_inherit" model="ir.ui.view">
            <field name="name">anode.slitting.inherit</field>
            <field name="model">anode.slitting</field>
            <field name="inherit_id" ref="fnet_mrp.anode_slitting_process_form_view"/>
            <field name="arch" type="xml">
                <div name="button_box" position="inside">
                    <button name="action_view_material_request" icon="fa-envelope"
                        type="object" class="oe_stat_button"
                        invisible="request_count == 0">
                        <field name="request_count" string="Material Request"
                            widget="statinfo" invisible="0"/>
                    </button>
                </div>
                <xpath expr="//header" position="inside">
                    <button name="action_material_request" type="object"
                        string="Request Material" invisible="state != 'draft'"/>
                </xpath>
            </field>
        </record>

