<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_stock_return_picking_inherit" model="ir.ui.view">
        <field name="name">stock.return.picking.form</field>
        <field name="model">stock.return.picking</field>
        <field name="inherit_id" ref="stock.view_stock_return_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_return_moves']" position="after">
               <group>
                <group>
                    <field name="return_value"/>
                </group>
                </group>
<!--                <field name="return_id"/>-->
            </xpath>
        </field>
    </record>

</odoo>