<!--                                <br/>-->
<!--                                <strong>Vehicle No:</strong><br/>-->
<!--                                <br/>-->
<!--                                <strong>Purpose:</strong><br/>-->
<!--                            </div>-->


                        </div>
                    </t>
                </t>
            </t>
        </template>

    </data>



</odoo>