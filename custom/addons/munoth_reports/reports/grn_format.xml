<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ═══════════════════════════════════════════════
             PAPER FORMAT
        ═══════════════════════════════════════════════ -->
        <record id="paperformat_grn_report" model="report.paperformat">
            <field name="name">A4 GRN Report</field>
            <field name="format">A4</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">15</field>
            <field name="margin_bottom">5</field>
            <field name="margin_left">10</field>
            <field name="margin_right">10</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">36</field>
            <field name="dpi">90</field>
        </record>

        <!-- ═══════════════════════════════════════════════
             REPORT ACTION
        ═══════════════════════════════════════════════ -->
        <record id="action_report_grn" model="ir.actions.report">
            <field name="name">Goods Received Note</field>
            <field name="model">stock.picking</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">munoth_reports.grn_report</field>
            <field name="report_file">munoth_reports.grn_report</field>
            <field name="paperformat_id" ref="munoth_reports.paperformat_grn_report"/>
            <field name="binding_model_id" ref="stock.model_stock_picking"/>
            <field name="binding_type">report</field>
        </record>

        <!-- ═══════════════════════════════════════════════
             REPORT TEMPLATE
        ═══════════════════════════════════════════════ -->
        <template id="grn_report">
            <t t-call="web.html_container">
                <t t-call="web.basic_layout">
                    <t t-foreach="docs" t-as="o">
                        <div class="page"
                             style="border: 1px solid black; padding: 25px; font-size: 14px; color: black !important; font-family: sans-serif;">
                            <!-- Top Right Info (Borderless) -->
                            <div style="float:right;width:25%;height:75px;">
                                        <t t-if="o.doc_no">
                                            <strong>Doc:</strong>
                                            <span t-field="o.doc_no"/>
                                        </t><br/>
                                        <t t-if="o.rev_no">
                                            <strong>Rev No:</strong>
                                            <span t-field="o.rev_no"/>
                                        </t>
                                        <br/>
                                        <t t-if="o.rev_date">
                                            <strong>Date:</strong>
                                            <span t-field="o.rev_date"
                                                  t-options='{"widget": "date","format": "dd-MM-yyyy"}'/>
                                        </t>
                                    </div>
                                    <div style="float:left;width:75%;height:75px;">

                                    </div>
                            <br/>
                            <!-- Centered Header: Logo & Name on Same Line -->
                            <div class="text-center" style="margin-top: 35px;">
                                <div style="display: block;">
                                    <img t-att-src="'/web/binary/company_logo?company=%s' % o.company_id.id"
                                         style="height:50px; display: inline-block; vertical-align: middle; margin-right: 15px;"/>
                                    <h1 style="display: inline-block; vertical-align: middle; font-size: 38px; margin: 0; font-weight: 800; letter-spacing: -1px;">
                                        Munoth Industries Limited
                                    </h1>
                                </div>

                                <div style="font-weight: bold; font-size: 13px; margin-top: 15px; line-height: 1.4;">
                                    <t t-esc="o.company_id.street"/>,
                                    <t t-if="o.company_id.street2"><t t-esc="o.company_id.street2"/>,
                                    </t>
                                    <t t-esc="o.company_id.city"/>
                                    <br/>
                                    <t t-esc="o.company_id.state_id.name"/>
                                    -
                                    <t t-esc="o.company_id.zip"/>
                                    <br/>
                                    India
                                </div>
                                <div class="mt-4" style="font-size: 14px;">
                                    <strong>GSTIN:
                                        <t t-esc="o.company_id.vat"/>
                                    </strong>
                                </div>
                            </div>

                            <div class="text-center" style="margin-top: 25px;">
                                <b style="font-size: 16px; text-decoration: underline;">Goods Received Note</b>
                            </div>

                            <!-- Info Section -->
                            <div class="row mt-3" style="line-height: 1.6;">
                                <div class="col-7">
                                    <div class="row no-gutters">
                                        <div class="col-3">
                                            <strong>GRN NO:</strong>
                                        </div>
                                        <div class="col-9">
                                            <span t-field="o.name"/>
                                        </div>
                                    </div>
                                    <div class="row no-gutters">
                                        <div class="col-3">
                                            <strong>PO Date:</strong>
                                        </div>
                                        <div class="col-9">
                                            <span t-field="o.purchase_id.date_approve"
                                                  t-options='{"widget": "date","format": "dd-MM-yyyy"}'/>
                                        </div>
                                    </div>
                                    <div class="row no-gutters">
                                        <div class="col-3">
                                            <strong>PO No:</strong>
                                        </div>
                                        <div class="col-9">
                                            <span t-field="o.purchase_id.name"/>
                                        </div>
                                    </div>
                                    <div class="mt-3">
                                        <strong>Name &amp; Address of the Supplier:</strong>
                                        <span t-field="o.partner_id.name"/>,
                                        <span t-field="o.partner_id"
                                              t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
                                    </div>
                                </div>
                                <div class="col-5">
                                    <div class="row no-gutters">
                                        <div class="col-6">
                                            <strong>Inward Date :</strong>
                                        </div>
                                        <div class="col-6">
                                            <span t-field="o.scheduled_date"
                                                  t-options='{"widget": "date","format": "dd-MM-yyyy"}'/>
                                        </div>
                                    </div>
                                    <div class="row no-gutters">
                                        <div class="col-6">
                                            <strong>Security Sl no :</strong>
                                        </div>
                                        <div class="col-6">
                                            <span t-field="o.security_inward_remarks"/>
                                        </div>
                                    </div>
                                    <div class="row no-gutters">
                                        <div class="col-6">
                                            <strong>Invoice Date:</strong>
                                        </div>
                                        <div class="col-6">
                                            <span t-field="o.invoice_date"
                                                  t-options='{"widget": "date","format": "dd-MM-yyyy"}'/>
                                        </div>
                                    </div>
                                    <div class="row no-gutters">
                                        <div class="col-6">
                                            <strong>Invoice No:</strong>
                                        </div>
                                        <div class="col-6">
                                            <span t-field="o.invoice_no"/>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Items Table -->
                            <table class="table table-bordered mt-4"
                                   style="border: 1px solid black !important; width: 100%; border-collapse: collapse;">
                                <thead>
                                    <tr style="height: 35px;">
                                        <th class="text-center align-middle"
                                            style="width: 5%; border: 1px solid black !important; font-weight: bold;">
                                            SI.No
                                        </th>
                                        <th class="align-middle"
                                            style="width: 35%; border: 1px solid black !important; font-weight: bold;">
                                            Item Description
                                        </th>
                                        <th class="text-center align-middle"
                                            style="width: 8%; border: 1px solid black !important; font-weight: bold;">
                                            UOM
                                        </th>
                                        <th class="text-center align-middle"
                                            style="width: 10%; border: 1px solid black !important; font-weight: bold;">
                                            Items Received
                                        </th>
                                        <th class="text-center align-middle"
                                            style="width: 10%; border: 1px solid black !important; font-weight: bold;">
                                            Items Accepted
                                        </th>
                                        <th class="text-center align-middle"
                                            style="width: 10%; border: 1px solid black !important; font-weight: bold;">
                                            Items Rejected
                                        </th>
                                        <th class="text-center align-middle"
                                            style="width: 22%; border: 1px solid black !important; font-weight: bold;">
                                            Reason For Rejection
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="counter" t-value="1"/>
                                    <tr t-foreach="o.move_ids" t-as="t">
                                        <td class="text-center align-top"
                                            style="border: 1px solid black !important; padding: 5px;">
                                            <span t-esc="counter"/>
                                            <t t-set="counter" t-value="counter + 1"/>
                                        </td>
                                        <td class="align-top" style="border: 1px solid black !important; padding: 5px;">
                                            <span t-field="t.description_picking"/>
                                        </td>
                                        <td class="text-center align-top"
                                            style="border: 1px solid black !important; padding: 5px;">
                                            <span t-field="t.product_uom.name"/>
                                        </td>
                                        <td class="text-center align-top"
                                            style="border: 1px solid black !important; padding: 5px;">
                                            <span t-field="t.quantity" t-options='{"widget": "float", "precision": 1}'/>
                                        </td>
                                        <td class="text-center align-top"
                                            style="border: 1px solid black !important; padding: 5px;">
                                            <span t-esc="t.quantity - (t.reversed_quantity or 0.0)"
                                                  t-options='{"widget": "float", "precision": 1}'/>
                                        </td>
                                        <td class="text-center align-top"
                                            style="border: 1px solid black !important; padding: 5px;">
                                            <span t-field="t.reversed_quantity"
                                                  t-options='{"widget": "float", "precision": 1}'/>
                                        </td>
                                        <td class="align-top" style="border: 1px solid black !important; padding: 5px;">
                                            <span t-field="t.reason"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>

                            <!-- Signature Section -->
                            <div class="row mt-1">
                                <div class="col-7">
                                    <div class="row no-gutters">
                                        <div class="col-4">
                                            <strong>Transporter:</strong>
                                        </div>
                                        <div class="col-8">
                                            <span t-field="o.transporter"/>
                                        </div>
                                    </div>
                                    <div class="row no-gutters">
                                        <div class="col-4">
                                            <strong>Vehicle Number :</strong>
                                        </div>
                                        <div class="col-8">
                                            <span t-field="o.vehicle_no"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-5">
                                    <div class="row no-gutters">
                                        <div class="col-6">
                                            <strong>Received By :</strong>
                                        </div>
                                        <div class="col-6">
                                            <span t-field="o.received_by.name"/>
                                        </div>
                                    </div>
                                    <div class="row no-gutters">
                                        <div class="col-6">
                                            <strong>Inspected By:</strong>
                                        </div>
                                        <div class="col-6">
                                            <span t-field="o.checked_by.name"/>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div style="margin-top: 80px;">
                                <div class="row">
                                    <div class="col-6 text-center">
                                        <strong>Prepared By:</strong>
                                        <br/>
                                        <div class="mt-4">
                                            <strong>
                                                <span t-field="o.prepared_by.name"/>
                                            </strong>
                                        </div>
                                    </div>
                                    <div class="col-6 text-center">
                                        <strong>Approved By:</strong>
                                        <br/>
                                        <div class="mt-4">_______________________</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </template>

    </data>
</odoo>