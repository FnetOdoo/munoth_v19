<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="paperformat_quotation_report" model="report.paperformat">
            <field name="name">A4 Quotation Report</field>
            <field name="format">A4</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">33</field>
            <field name="margin_bottom">20</field>
            <field name="margin_left">5</field>
            <field name="margin_right">5</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">33</field>
            <field name="dpi">90</field>
        </record>

        <record id="quotation_report" model="ir.actions.report">
            <field name="name">Munoth Sale Quotation/Order</field>
            <field name="model">sale.order</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">munoth_reports.quotation_munoth_report</field>
            <field name="report_file">munoth_reports.quotation_munoth_report</field>
            <field name="paperformat_id" ref="munoth_reports.paperformat_quotation_report"/>
            <field name="binding_model_id" ref="sale.model_sale_order"/>
            <field name="print_report_name">(object.state in ('draft', 'sent') and 'Quotation - %s' % (object.name)) or
                'Order - %s' % (object.name)
            </field>
            <field name="binding_type">report</field>
        </record>

        <!-- Main Layout with Header/Footer -->
        <template id="external_layout_striped_so">
            <t t-if="not o" t-set="o" t-value="doc"/>
            <t t-if="not company">
                <t t-if="company_id">
                    <t t-set="company" t-value="company_id"/>
                </t>
                <t t-elif="o and 'company_id' in o and o.company_id.sudo()">
                    <t t-set="company" t-value="o.company_id.sudo()"/>
                </t>
                <t t-else="else">
                    <t t-set="company" t-value="res_company"/>
                </t>
            </t>

            <style>
                .currency_symbol {
                display: inline-block;
                width: 12px;
                height: 12px;
                background-image:
                url('data:image/svg+xml;base64,');
                background-repeat: no-repeat;
                background-position: center;
                vertical-align: middle;
                margin-right: 2px;
                }
                /* Tighten header and footer padding */
                .o_background_header {
                padding-top: 4px !important;
                padding-bottom: 4px !important;
                }
                .o_background_footer {
                padding-top: 4px !important;
                padding-bottom: 2px !important;
                }
            </style>

            <!-- HEADER -->
            <div t-attf-class="o_company_#{company.id}_layout header" t-att-style="report_header_style"
                 style="padding: 0; margin: 0;">
                <div class="o_background_header" style="padding: 4px 0 4px 0;">
                    <div class="row" style="margin: 0;">
                        <div style="width:10%;">
                            <img t-if="company.logo" t-att-src="image_data_uri(company.logo)"
                                 style="width:90px;" alt="Logo"/>
                        </div>
                        <div class="company_address" style="width:75%; padding-left: 20px;">
                            <div style="font-size: 20px; font-weight: bold; text-transform: uppercase; color:#333333;">
                                <span t-field="company.name"/>
                            </div>
                            <div style="font-size: 16px; line-height: 1.2; color:#636363;">
                                <span t-if="company.street" t-field="company.street"/>,
                                <br/>
                                <span t-if="company.street2" t-field="company.street2"/>
                                <br/>
                                <span t-if="company.city" t-field="company.city"/>
                                <t t-if="company.zip">-
                                    <span t-field="company.zip"/>
                                </t>
                                ,
                                <br/>
                                <span t-if="company.state_id" t-field="company.state_id"/>
                                <br/>
                                <span t-if="company.country_id" t-field="company.country_id"/>
                                <br/>
                            </div>
                        </div>
                    </div>
                    <div style="border-bottom: 1px solid #dee2e6; margin-top: 4px;"/>
                </div>
            </div>

            <!-- BODY -->
            <div t-attf-class="o_company_#{company.id}_layout article o_report_layout_striped {{ 'o_layout_background' if company.layout_background in ['Geometric', 'Custom'] else '' }}"
                 t-attf-style="background-image: url({{ 'data:image/png;base64,%s' % company.layout_background_image.decode('utf-8') if company.layout_background_image and company.layout_background == 'Custom' else '/base/static/img/bg_background_template.jpg' if company.layout_background == 'Geometric' else ''}});"
                 t-att-data-oe-model="o and o._name"
                 t-att-data-oe-id="o and o.id"
                 t-att-data-oe-lang="o and o.env.context.get('lang')">
                <main>
                    <t t-out="0"/>
                </main>
            </div>

            <!-- FOOTER -->
            <div t-attf-class="o_company_#{company.id}_layout footer o_background_footer"
                 style="padding: 0; margin: 0;">
                <div class="text-center"
                     style="border-top: 1px solid black; border-bottom: 1px solid black; padding: 3px 5px;">
                    <t t-if="company.phone">
                        <strong>Phone:</strong>
                        <span t-field="company.phone"/>
                    </t>
                    <t t-if="company.email">
                        &#160;&#160;<strong>Email:</strong>
                        <span t-field="company.email"/>
                    </t>
                    <t t-if="company.website">
                        &#160;&#160;<strong>Website:</strong>
                        <span t-field="company.website"/>
                    </t>
                </div>
                <div t-if="report_type == 'pdf'" class="text-muted text-center"
                     style="margin-top: 1px; font-size: 12px;">
                    Page
                    <span class="page"/>
                    of
                    <span class="topage"/>
                </div>
            </div>
        </template>

        <!-- Template for SO Content -->
        <template id="quotation_munoth_report_new">
            <t t-call="munoth_reports.external_layout_striped_so">
                <div class="page" style="margin-top: 0px !important; padding-top: 0px !important;">
                    <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)"/>

                    <!-- ADDRESSES -->
                    <div class="row" style="margin-top: 0px; padding-top: 0px;">
                        <div class="col-6" style="font-size: 16px; color:#636363;">
                            <strong>Invoicing Address:</strong>
                            <br/>
                            <div t-field="o.company_id.partner_id"
                                 t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": True}'/>
                        </div>
                        <div class="col-6" style="font-size: 16px; color:#636363; padding-left: 20px;">
                            <br/>
                            <div t-field="o.partner_id"
                                 t-options='{"widget": "contact", "fields": ["address", "name", "phone", "email"], "no_marker": True}'/>
                            <t t-if="o.partner_id.vat">
                                <strong>GSTIN:</strong>
                                <span t-field="o.partner_id.vat"/>
                            </t>
                        </div>
                    </div>

                    <!-- SHIPPING ADDRESS -->
                    <div style="margin-top:15px; font-size:16px; color:#636363;">
                        <strong>Shipping Address:</strong>
                        <br/>
                        <span t-field="o.partner_shipping_id.name"/>
                        <br/>
                        <t t-if="o.partner_shipping_id.street">
                            <span t-field="o.partner_shipping_id.street"/>
                            <br/>
                        </t>
                        <t t-if="o.partner_shipping_id.street2">
                            <span t-field="o.partner_shipping_id.street2"/>
                            <br/>
                        </t>
                        <t t-if="o.partner_shipping_id.city">
                            <span t-field="o.partner_shipping_id.city"/>
                        </t>
                        <t t-if="o.partner_shipping_id.zip">
                            -
                            <span t-field="o.partner_shipping_id.zip"/>
                        </t>
                        <br/>
                        <t t-if="o.partner_shipping_id.state_id">
                            <span t-field="o.partner_shipping_id.state_id"/>
                            <br/>
                        </t>
                        <t t-if="o.partner_shipping_id.country_id">
                            <span t-field="o.partner_shipping_id.country_id"/>
                            <br/>
                        </t>
                        <t t-if="o.partner_shipping_id.phone">
                            <span t-field="o.partner_shipping_id.phone"/>
                            <br/>
                        </t>

                        <h2 style="font-size: 30px; color:#636363; margin-bottom: 4px;">
                            <t t-if="not (env.context.get('proforma', False) or is_pro_forma)">
                                <span t-if="o.state not in ['draft','sent']">Order #</span>
                                <span t-if="o.state in ['draft','sent']">Quotation #</span>
                            </t>
                            <t t-if="env.context.get('proforma', False) or is_pro_forma">
                                <span>Pro-Forma Invoice #</span>
                            </t>
                            <span t-field="o.name"/>
                        </h2>
                        <br/>
                        <div t-if="o.user_id" class="col-3 bm-2">
                            <strong style="color:black;">Salesperson:</strong>
                            <br/>
                            <span style="color:#636363;" t-field="o.user_id.name"/>
                        </div>
                    </div>

                    <!-- ORDER LINES TABLE -->
                    <table style="border-top:1px solid #dee2e6;" class="table table-borderless">
                        <thead>
                            <tr>
                                <th name="th_description" style="width:50%;">
                                    <strong>Description</strong>
                                </th>
                                <th name="th_quantity" class="text-right" style="width:10%;">
                                    <strong>Quantity</strong>
                                </th>
                                <th name="th_price_unit" class="text-right" style="width:10%;">
                                    <strong>Unit Price</strong>
                                </th>
                                <th name="th_taxes" style="width:10%;">
                                    <strong>Taxes</strong>
                                </th>
                                <th name="th_amount" class="text-right" style="width:10%;">
                                    <strong>Amount</strong>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="current_subtotal" t-value="0"/>
                            <t t-foreach="o.order_line" t-as="line">
                                <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal"
                                   groups="account.group_show_line_subtotals_tax_excluded"/>
                                <t t-set="current_subtotal" t-value="current_subtotal + line.price_total"
                                   groups="account.group_show_line_subtotals_tax_included"/>
                                <tr t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                                    <t t-if="not line.display_type">
                                        <t t-set="row_bg"
                                           t-value="'background-color:#f0f0f5;' if line_index % 2 == 0 else ''"/>
                                        <td id="product" t-att-style="row_bg" style="width:50%;">
                                            <span t-field="line.name"/>
                                        </td>
                                        <td class="text-right" t-att-style="row_bg" style="width:10%;">
                                            <span t-field="line.product_uom_qty"/>
                                            <span t-field="line.product_uom_id.name" groups="uom.group_uom"/>
                                        </td>
                                        <td class="text-right" t-att-style="row_bg" style="width:10%;">
                                            <span class="currency_symbol"/>
                                            <span t-field="line.price_unit"/>
                                        </td>
                                        <td name="td_taxes" t-att-style="row_bg" style="width:10%;">
                                            <span t-esc="', '.join(map(lambda x: x.name, line.tax_ids))"/>
                                        </td>
                                        <td class="text-right" t-att-style="row_bg">
                                            <span t-field="line.price_subtotal"
                                                  t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                        </td>
                                    </t>
                                    <t t-if="line.display_type == 'line_section'">
                                        <td colspan="99" id="section">
                                            <span t-field="line.name"/>
                                        </td>
                                        <t t-set="current_section" t-value="line"/>
                                        <t t-set="current_subtotal" t-value="0"/>
                                    </t>
                                    <t t-if="line.display_type == 'line_note'">
                                        <td colspan="99" id="note">
                                            <span t-field="line.name"/>
                                        </td>
                                    </t>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <!-- TOTALS -->
                    <div id="total" class="row justify-content-end">
                        <div class="col-4">
                            <table class="table table-borderless">
                                <tr style="border-top:1px solid grey;">
                                    <td>
                                        <strong>Untaxed Amount</strong>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="o.amount_untaxed"
                                              t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                </tr>
                                <t t-foreach="o.tax_totals['subtotals']" t-as="subtotal">
                                    <t t-foreach="subtotal['tax_groups']" t-as="tax_group">
                                        <tr>
                                            <td><strong t-esc="tax_group['group_name']"/>:
                                            </td>
                                            <td class="text-right">
                                                <span t-esc="tax_group['tax_amount_currency']"
                                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                                <tr class="o_total" style="border-top:1px solid grey; color:black;">
                                    <td>
                                        <strong>Total</strong>
                                    </td>
                                    <td class="text-right">
                                        <strong>
                                            <span t-field="o.amount_total"
                                                  t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                        </strong>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <!-- TERMS -->
                    <div class="mt16" style="line-height: 1.8; font-size: 16px;">
                        <t t-if="o.payment_term_id">
                            <strong>Payment Terms :</strong>
                            <span t-field="o.payment_term_id"/>
                            <br/>
                        </t>
                        <t t-if="o.validity_date">
                            <strong>Quotation validity :</strong>
                            <span t-field="o.validity_date"
                                  t-options='{"widget": "date","format": "dd-MM-yyyy"}'/>
                            <br/>
                        </t>
                        <t t-if="o.commitment_date">
                            <strong>Delivery lead time :</strong>
                            <span t-field="o.commitment_date"
                                  t-options='{"widget": "date","format": "dd-MM-yyyy"}'/>
                            <br/>
                        </t>
                    </div>

                    <!-- BANK DETAILS -->
                    <div class="mt16" t-if="doc.company_details">
                        <strong>
                            <u>Company's Bank Details:</u>
                        </strong>
                        <table style="margin-top: 4px;" class="table table-borderless">
                            <tr>
                                <td style="width:150px; padding:2px 5px; font-size:16px;">Holder Name</td>
                                <td style="width:8px; padding:2px 5px; font-size:16px;">:</td>
                                <td style="padding:2px 5px; font-size:16px;">
                                    <span t-field="doc.company_details.acc_holder_name"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="width:150px; padding:2px 5px; font-size:16px;">Bank Name</td>
                                <td style="width:8px; padding:2px 5px; font-size:16px;">:</td>
                                <td style="padding:2px 5px; font-size:16px;">
                                    <span t-field="doc.company_details.bank_id.name"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="width:150px; padding:2px 5px; font-size:16px;">A/c No</td>
                                <td style="width:8px; padding:2px 5px; font-size:16px;">:</td>
                                <td style="padding:2px 5px; font-size:16px;">
                                    <span t-field="doc.company_details.acc_number"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="width:150px; padding:2px 5px; font-size:16px;">Branch &amp; IFSC Code</td>
                                <td style="width:8px; padding:2px 5px; font-size:16px;">:</td>
                                <td style="padding:2px 5px; font-size:16px;">
                                    <span t-field="doc.company_details.bank_id.bic"/>
                                </td>
                            </tr>
                        </table>
                    </div>

                </div><!-- /page -->
            </t>
        </template>

        <!-- Main entry-point template -->
        <template id="quotation_munoth_report">
            <t t-foreach="docs" t-as="doc">
                <t t-set="o" t-value="doc"/>
                <t t-call="munoth_reports.quotation_munoth_report_new"/>
            </t>
        </template>

    </data>
</odoo>