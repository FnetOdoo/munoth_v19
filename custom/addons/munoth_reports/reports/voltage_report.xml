<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="paperformate_voltage_process_report" model="report.paperformat">
            <field name="name">A4 voltage Production</field>
            <field name="format">A4</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Landscape</field>
            <field name="margin_top">50</field>
            <field name="margin_bottom">25</field>
            <field name="margin_left">10</field>
            <field name="margin_right">10</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">15</field>
            <field name="dpi">90</field>
        </record>
        <record id="voltage_process_report" model="ir.actions.report">
            <field name="name">Voltage Production</field>
            <field name="model">voltage.test</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">munoth_reports.voltage_production_munoth_report</field>
            <field name="report_file">munoth_reports.voltage_production_munoth_report</field>
            <field name="paperformat_id" ref="munoth_reports.paperformate_voltage_process_report"/>
            <field name="binding_model_id" ref="fnet_mrp.model_voltage_test"/>
            <field name="binding_type">report</field>
        </record>
        <template id="voltage_production_munoth_report">
            <t t-call="web.html_container">
                <t t-call="web.basic_layout">
                    <t t-foreach="docs" t-as="o">
                        <div class="header">
                            <div style="width:20%;float:left;border-top:1px solid black;border-bottom:1px solid black;border-left:1px solid black;height:70px;">
                                <center><img src="/web/binary/company_logo" style="height:68px;" class="center"/></center>
                            </div>
                            <div style="width:80%;float:right;border-right:1px solid black;border-top:1px solid black;border-bottom:1px solid black;padding-right:5px;height:70px;">
                                <h3 style="text-align:center;color:purple!important;"><strong><h3 style="font-weight:bold;font-size:25px;text-align:center;padding-top:10px;">MUNOTH INDUSTRIES LIMITED</h3></strong></h3>
                            </div>
                        </div>
                        <div class='page'>
                            <div>
                                <table style="width:100%;">
                                    <tr style="height:50px;padding-top:5px;">
                                        <td style="text-align:left;width:70%;border-top:1px solid black;border-right:1px solid black;border-left:1px solid black;">
                                            <b style="font-size:25px;">Machine Name: IR/OCV</b>
                                        </td>
                                        <td style="text-align:left;width:30%;border-right:1px solid black;border-top:1px solid black;padding-left:3px;">
                                            <b>Doc No:<span t-esc="o.name"/></b>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                            <div>
                                <table style="width:100%;">
                                    <tr style="height:50px;padding-top:5px;">
                                        <td style="text-align:center;width:70%;border:1px solid black;">
                                            <b style="font-size:25px;">Hourly Production Report</b>
                                        </td>
                                        <td style="text-align:left;width:30%;border:1px solid black;padding-left:3px;">
                                            <b>Effective dt:<span t-esc="o.name"/></b>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                            <div>
                                <table style="width:100%;">
                                    <tr style="height:50px;padding-top:5px;">
                                        <td style="text-align:left;width:70%;border:1px solid black;">
                                            <b style="font-size:20px;">Hourly production target: </b>
                                        </td>
                                        <td style="text-align:left;width:30%;border:1px solid black;padding-left:3px;">
                                            <b>Revision No:<span t-esc="o.name"/></b>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                            <table style="width:100%;border-right:1px solid black;border-bottom:1px solid black;border-top:1px solid black;border-left:1px solid black;page-break-before: avoid;max-height:500px;" cellspacing="0">
                                <thead style="line-height: 1.5;">
                                    <th style="font-weight:bold;font-size:15px;height:15px;width:5%;text-align:center;vertical-align:middle;border-right:1px solid black;">
                                        <!--                                        S.no-->
                                    </th>
                                    <th style="font-weight:bold;font-size:15px;height:15px;width:10%;text-align:center;border-top:1px solid black;vertical-align:middle;border-right:1px solid black;">
                                        <!--                                        Time-->
                                    </th>
                                    <th style="font-weight:bold;font-size:15px;height:15px;width:10%;text-align:center;border-top:1px solid black;vertical-align:middle;border-right:1px solid black;">
                                        <!--                                        Actual Production Nos-->
                                    </th>
                                    <th style="font-weight:bold;font-size:15px;height:15px;width:10%;text-align:center;border-top:1px solid black;vertical-align:middle;border-right:1px solid black;">
                                        <!--                                        Accepted Production Nos-->
                                    </th>
                                    <th style="font-weight:bold;font-size:15px;height:15px;width:15%;text-align:center;border-top:1px solid black;vertical-align:middle;border-right:1px solid black;">
                                        <!--                                        Rejection Nos-->
                                    </th>
                                    <th style="font-weight:bold;font-size:15px;height:15px;width:15%;text-align:right;border-top:1px solid black;vertical-align:right;">
                                        Default
                                    </th>
                                    <th style="font-weight:bold;font-size:15px;height:15px;width:10%;text-align:center;border-top:1px solid black;border-bottom:1px solid black;vertical-align:middle;border-right:1px solid black;">
                                        <!--                                        IR-->
                                    </th>
                                    <th style="font-weight:bold;font-size:15px;height:10px;width:25%;border-right:1px solid black;text-align:center;border-top:1px solid black;vertical-align:middle;">
                                        <!--                                        Remarks-->
                                    </th>
                                </thead>
                                <thead style="line-height: 1.5;">
                                    <th style="font-weight:bold;font-size:15px;height:15px;width:5%;border-right:1px solid black;text-align:center;border-bottom:1px solid black;vertical-align:middle;">
                                        S.no
                                    </th>
                                    <th style="font-weight:bold;font-size:15px;height:15px;width:10%;border-right:1px solid black;text-align:center;border-bottom:1px solid black;vertical-align:middle;">
                                        Time
                                    </th>
                                    <th style="font-weight:bold;font-size:15px;height:15px;width:10%;border-right:1px solid black;text-align:center;border-bottom:1px solid black;vertical-align:middle;">
                                        Actual Production Nos
                                    </th>
                                    <th style="font-weight:bold;font-size:15px;height:15px;width:10%;border-right:1px solid black;text-align:center;border-bottom:1px solid black;vertical-align:middle;">
                                        Accepted Production Nos
                                    </th>
                                    <th style="font-weight:bold;font-size:15px;height:15px;width:15%;border-right:1px solid black;text-align:center;border-bottom:1px solid black;vertical-align:middle;">
                                        Rejection Nos
                                    </th>
                                    <th style="font-weight:bold;font-size:15px;height:15px;width:15%;border-right:1px solid black;text-align:center;border-bottom:1px solid black;border-top:1px solid black;vertical-align:middle;">
                                        Voltage
                                    </th>
                                    <th style="font-weight:bold;font-size:15px;height:15px;width:10%;border-right:1px solid black;text-align:center;border-bottom:1px solid black;vertical-align:middle;">
                                        IR
                                    </th>
                                    <th style="font-weight:bold;font-size:15px;height:10px;width:25%;border-right:1px solid black;text-align:center;border-bottom:1px solid black;border-top:1px solid black;vertical-align:middle;">
                                        Remarks
                                    </th>
                                </thead>
                                <tbody>
                                    <t t-set="counter" t-value="1"/>
                                    <tr style="font-size: 16px;" t-foreach="docs.component_ids" t-as="t">
                                        <td style="width:5%;border-right:1px solid black;text-align:center;vertical-align:top;padding-top:0px;border:1px solid black;">
                                            <span style="text-align:center;" t-esc="counter"/>
                                            <t t-set="counter" t-value="counter+1"/>
                                        </td>
                                        <td style="width:10%;padding-left:2px;border-right:1px solid black;text-align:center;valign:top;vertical-align:top;padding-top:0px;">
                                            <span t-field="t.product_id"/>
                                        </td>
                                        <td style="width:10%;text-align:center;border-right:1px solid black;valign:top;vertical-align:top;padding-top:0px;">
                                            <span t-field="t.name"/>
                                        </td>
                                        <td style="width:10%;text-align:center;border-right:1px solid black;valign:top;vertical-align:top;padding-top:0px;">
                                            <!--                                            <span t-esc="t.net_weight"/>-->
                                        </td>
                                        <td style="width:15%;text-align:center;border-right:1px solid black;valign:top;vertical-align:top;padding-top:0px;">
                                            <!--                                            <span t-esc="t.total_net_weight"/>-->
                                        </td>
                                        <td style="width:15%;text-align:center;border-right:1px solid black;valign:top;vertical-align:top;padding-top:0px;">
                                            <!--                                            <span t-esc="t.final_description"/>-->
                                        </td>
                                        <td style="width:10%;text-align:center;border-right:1px solid black;valign:top;vertical-align:top;padding-top:0px;">
                                            <!--                                            <span t-esc="t.remarks"/>-->
                                        </td>
                                        <td style="width:25%;text-align:center;border-right:1px solid black;border-bottom:1px solid black;valign:top;vertical-align:top;padding-top:0px;">
                                            <!--                                            <span t-esc="t.remarks"/>-->
                                        </td>
                                    </tr>
                                    <tr style="height:50px; border:1px solid black;">
                                        <td colspan="8"
                                            style="text-align:left;padding:5px;font-size:18px;vertical-align:middle;">
                                            <b>Total Amount:
                                                <!--                                            <span t-esc="doc.amount_total_words"/>-->
                                            </b>
                                        </td>
                                    </tr>
                                    <tr style="height:50px; border:1px solid black;">
                                        <td colspan="8"
                                            style="text-align:left;padding:5px;font-size:18px;border-right:1px solid black;vertical-align:left;">
                                            <b>
                                                Note: Rejection details Voltage  (A-High ,B-Low), IR (C-High,D-Low)
                                            </b>
                                        </td>
                                    </tr>
                                    <tr style="height:50px; border:1px solid black;">
                                        <td colspan="3"
                                            style="text-align:left;padding:5px;font-size:18px;vertical-align:left;">
                                            <b>
                                                Operator :
                                            </b>
                                        </td>
                                        <td colspan="2"
                                            style="text-align:left;padding:5px;font-size:18px;vertical-align:left;">
                                            <b>
                                                Supervisor :
                                            </b>
                                        </td>
                                        <td colspan="3"
                                            style="text-align:left;padding:5px;font-size:18px;border-right:1px solid black;vertical-align:left;">
                                            <b>
                                                Shift Incharge :
                                            </b>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </t>
                </t>
            </t>
        </template>



    </data>
</odoo>