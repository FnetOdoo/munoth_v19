<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_purchase_order_tree_approval_rules" model="ir.ui.view">
            <field name="name">purchase.order.tree.approval.rules</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='state']" position="after">
                    <field name='ready_for_po' column_invisible="1"/>
                    <field name='approval_state'/>
                </xpath>
            </field>
        </record>

        <record id="view_purchase_order_list_approval_rules" model="ir.ui.view">
            <field name="name">purchase.order.form.approval.rules</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
            <field name="arch" type="xml">
                <field name="state" position="after">
                    <field name="approval_state" optional="show" widget="badge"
                           decoration-info="approval_state == 'approved'"
                           decoration-danger="approval_state == 'to_approve'"/>
                </field>
                <field name="state" position="replace">
                    <field name="state" optional="show" widget="badge"
                           decoration-success="state in ('purchase', 'done')"
                           decoration-warning="state == 'bid received'"
                           decoration-danger="state == 'cancel'"
                           decoration-primary="state == 'to approve'"
                           decoration-info="state in ('draft', 'sent')"/>
                </field>
            </field>
        </record>

        <record id="view_purchase_order_form_approval_rules" model="ir.ui.view">
            <field name="name">purchase.order.form.approval.rules</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
                <!-- Ribbons: attrs replaced with inline invisible domain -->
                <div name="button_box" position='before'>
                    <widget name="web_ribbon" title="Requested"
                            invisible="approval_state != 'to_approve'"/>
                    <widget name="web_ribbon" title="Approved"
                            invisible="approval_state != 'approved'"/>
                </div>

                <xpath expr="//field[@name='currency_id']" position="after">
                    <field name='editable_compute' invisible="1"/>
                    <field name='approval_state' invisible="1"/>
                    <field name='user_ids' widget="many2many_tags" invisible="1" readonly="1"/>
                </xpath>

                <!-- tax_totals_json renamed to tax_totals in Odoo 17 -->
                <xpath expr="//field[@name='tax_totals']" position="after">
                    <div class="oe_subtotal_footer_separator oe_inline">
                        <label for="amount_in_company_currency" class="oe_inline"/>
                    </div>
                    <field name="amount_in_company_currency" nolabel="1"
                           class="oe_subtotal_footer_separator"
                           widget='monetary'
                           options="{'currency_field': 'company_currency'}"/>
                    <field name="company_currency" invisible="1"/>
                </xpath>

                <!-- Send For Approval button -->
                <xpath expr="//button[@name='button_cancel']" position="before">
                    <button name="action_send_for_approval" type="object"
                            string="Send For Approval"
                            groups="purchase_approval.group_first_approval_user"
                            invisible="
                                (state != 'bid received' and send_for_approval == True) or
                                (state == 'bid received' and send_for_approval == True) or
                                (state != 'bid received' and send_for_approval != True) or
                                purchase_order_approval == False or
                                purchase_order_approval_rule_id == False or
                                purchase_order_approval_rule_ids == []
                            "/>
                </xpath>

                <!-- Warning span -->
                <xpath expr="//button[last()]" position="after">
                    <span class="label label-danger"
                          invisible="ready_for_po == True or send_for_approval == False">
                        RFQ is not fully approved yet!
                    </span>
                </xpath>

                <!-- Confirm Order button -->
                <xpath expr="//button[@id='bid_confirm']" position="replace">
                    <button name="button_confirm" type="object" string="Confirm Order"
                            class="oe_highlight" id="bid_confirm" data-hotkey="v"
                            groups="purchase_approval.group_confirm_order_user"
                            invisible="state not in ['bid received'] or ready_for_po == False"/>
                </xpath>

                <!-- Approval Hierarchy and History pages: tree → list in Odoo 17 -->
                <xpath expr="//notebook//page[@name='purchase_delivery_invoice']" position="after">
                    <page string='Approval Hierarchy'
                          invisible="purchase_order_approval == False or purchase_order_approval_rule_id == False">
                        <field name='purchase_order_approval_rule_ids' nolabel="1">
                            <list editable='bottom'>
                                <field name='sequence'/>
                                <field name='approval_role'/>
                                <field name='users' widget="many2many_tags"/>
                                <field name='date'/>
                                <field name='is_approved' column_invisible="1"/>
                                <field name="user_id"/>
                                <field name="state"/>
                            </list>
                        </field>
                    </page>
                    <page string='Approval History'
                          invisible="purchase_order_approval == False or purchase_order_approval_rule_id == False">
                        <field name='purchase_order_approval_history' nolabel="1">
                            <list>
                                <field name='user'/>
                                <field name='date'/>
                                <field name="state"/>
                                <field name="rejection_reason"/>
                            </list>
                        </field>
                    </page>
                </xpath>

                <!-- Order line readonly logic -->
                <xpath expr="//field[@name='order_line']" position="attributes">
                    <attribute name="readonly">editable_compute != True or state in ['purchase', 'done', 'cancel']</attribute>
                </xpath>

                <!-- send_approve_process inside header -->
                <xpath expr="//header" position="inside">
                    <field name="send_approve_process" invisible="1"/>
                </xpath>

                <!-- Approve/Reject buttons and invisible fields -->
                <xpath expr="//button[@name='button_cancel']" position="after">
                    <button name="action_button_approve" string="Approve Quotation" type="object"
                            groups="purchase_approval.group_second_approval_user"
                            invisible="state not in ['bid received'] or approve_button != True"/>
                    <button name="reject_quotation" type="object" string="Reject Quotation"
                            groups="purchase_approval.group_second_approval_user"
                            invisible="state not in ['bid received'] or approve_button != True"/>
                    <field name='approve_button' invisible="1"/>
                    <field name='ready_for_po' invisible="1"/>
                    <field name='send_for_approval' invisible="1"/>
                    <field name='is_rejected' invisible="1"/>
                    <field name='dummy_compute' invisible="1"/>
                    <field name='purchase_order_approval_rule_id' invisible="1"/>
                    <field name='purchase_order_approval' invisible="1"/>
                </xpath>

                <!-- partner_id and date_order readonly when sent for approval -->
                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name='readonly'>send_for_approval == True</attribute>
                </xpath>
                <xpath expr="//field[@name='date_order']" position="attributes">
                    <attribute name='readonly'>send_for_approval == True</attribute>
                </xpath>
            </field>
        </record>

        <!-- Action: PO to Approve -->
        <record id="action_to_approve_purchase_orders" model="ir.actions.act_window">
            <field name="name">PO to Approve</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">purchase.order</field>
            <field name="view_mode">list,form,calendar,graph</field>
            <field name="search_view_id" ref="purchase.view_purchase_order_filter"/>
            <field name="domain">[('approve_button', '=', True), ('state', 'not in', ['cancel'])]</field>
            <field name="context">{'purchase_approve': True}</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to create a RFQ that can be converted into a purchase order.
                </p>
                <p>
                    Odoo will help you efficiently handle the complete purchase flow:
                    RFQ, purchase order, delivery, invoicing and payment.
                </p>
            </field>
        </record>

        <!-- Rejection Reason Form: tree → list -->
        <record id="view_rfq_rejection_reason_form" model="ir.ui.view">
            <field name="name">rfq.rejection.reason.form</field>
            <field name="model">rfq.rejection.reason</field>
            <field name="arch" type="xml">
                <form string="Rejection Reason">
                    <group>
                        <field name="reason"/>
                    </group>
                    <footer>
                        <button string='Reject' name="button_reject" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-default" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Team field inherit -->
        <record id="purchase_order_form_inherit_access" model="ir.ui.view">
            <field name="name">purchase.order.form.inherit.access</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
                <field name="user_id" position="after">
                    <field name="team_id"/>
                </field>
            </field>
        </record>

        <!-- Menu item -->
        <menuitem action="action_to_approve_purchase_orders"
                  id="menu_to_approve_purchase_orders"
                  name='Quotations to Approve'
                  parent="purchase.menu_procurement_management"
                  sequence="1"/>
    </data>
</odoo>