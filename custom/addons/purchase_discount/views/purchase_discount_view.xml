<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Purchase Order Line Form View -->
    <record id="purchase_order_line_form2_inherit_discount" model="ir.ui.view">
        <field name="name">purchase.order.line.form.discount</field>
        <field name="model">purchase.order.line</field>
        <field name="inherit_id" ref="purchase.purchase_order_line_form2"/>
        <field name="arch" type="xml">
            <field name="price_unit" position="after">
                <field name="discount"/>
            </field>
        </field>
    </record>

    <!-- Purchase Order Line List View -->
    <record id="purchase_order_line_list_inherit_discount" model="ir.ui.view">
        <field name="name">purchase.order.line.list.discount</field>
        <field name="model">purchase.order.line</field>
        <field name="inherit_id" ref="purchase.purchase_order_line_tree"/>
        <field name="arch" type="xml">
            <field name="price_unit" position="after">
                <field name="discount"/>
            </field>
        </field>
    </record>

    <!-- Purchase Order Main Form -->
    <record id="purchase_order_form_inherit_discount" model="ir.ui.view">
        <field name="name">purchase.order.form.discount</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list/field[@name='price_unit']" position="after">
                <field name="discount" readonly="qty_invoiced != 0"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/form//field[@name='price_unit']" position="after">
                <field name="discount" readonly="qty_invoiced != 0"/>
            </xpath>

        </field>
    </record>

</odoo>