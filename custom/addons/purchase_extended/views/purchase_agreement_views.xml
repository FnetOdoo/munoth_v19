<?xml version="1.0"?>
<odoo>
    <!-- Add State based on the odoo 15 -->
    <record model="ir.ui.view" id="inherit_view_purchase_requisition_form">
        <field name="name">purchase.requisition.inherit.validate</field>
        <field name="model">purchase.requisition</field>
        <field name="inherit_id" ref="purchase_requisition.view_purchase_requisition_form"/>
        <field name="priority" eval="20"/>
        <field name="arch" type="xml">
            <!-- Hide vendor_id field -->
            <field name="vendor_id" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>

            <!-- Add customer_id and lead_id after reference -->
            <xpath expr="//field[@name='requisition_type']" position="after">
                <field name="customer_id" readonly="state != 'draft'"/>
                <field name="lead_id" readonly="state != 'draft'"/>
            </xpath>
            <xpath expr="//field[@name='reference']" position="after">
                <field name="schedule_date" readonly="state != 'draft'"/>
            </xpath>
            <!-- Hide reference field -->
            <xpath expr="//field[@name='reference']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Add Received Bids page inside notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="Received Bids">
                    <field name="bid_received_line">
                        <list editable="bottom" create="false" delete="false">
                            <field name="valid_qoute"/>
                            <field name="qty_selected" required="valid_qoute"/>
                            <field name="tender_id" invisible="1" required="1"/>
                            <field name="requisition_line_id" invisible="1"/>
                            <field name="purchase_order_id"/>
                            <field name="vender_id"/>
                            <field name="product_id"/>
                            <field name="quantity" sum="Total Quantity"/>
                            <field name="unit_measure"/>
                            <field name="purchase_unit_price" sum="Total Purchase Unit Price" widget="monetary"/>
                            <field name="purchase_total_price" sum="Total Purchase Price" widget="monetary"/>
                            <field name="unit_price" sum="Total Unit Price" widget="monetary"/>
                            <field name="sub_total" sum="Total Price" widget="monetary"/>
                        </list>
                    </field>
                </page>
            </xpath>

            <!--                &lt;!&ndash; Hide first two header buttons &ndash;&gt;-->
            <xpath expr="//header/button[1]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <!--                <xpath expr="//header/button[2]" position="attributes">-->
            <!--                    <attribute name="invisible">1</attribute>-->
            <!--                </xpath>-->

            <!-- Add Create RFQs button before action_done -->
            <xpath expr="//button[@name='action_done']" position="before">
                <button name="create_rfq" type="object" invisible="state not in ('confirmed','open')" string="Create RFQs" class="oe_highlight"/>
            </xpath>
            <xpath expr="//button[@name='action_confirm']" position="after">
                <button name="action_open" type="object" invisible="state not in ('confirmed')" string="Validate" class="oe_highlight"/>
            </xpath>
            <xpath expr="//button[@name='action_done']" position="attributes">
                <attribute name="invisible">state not in ('open',) or requisition_type == 'purchase_template'
                </attribute>
            </xpath>
            <!-- Add vendor_ids before product_id in line -->
            <xpath expr="//field[@name='product_id']" position="before">
                <field name="vendor_ids" widget="many2many_tags"/>
            </xpath>
        </field>
    </record>
</odoo>