<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data noupdate="1">

        <record id="production_estimation_block_remove" model="ir.cron">
            <field name="name">Remove block production in Estimation</field>
            <field name="model_id" ref="model_mrp_estimation"/>
            <field name="state">code</field>
            <field name="code">model.action_production_block_remove()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>


        <record id="production_estimation_expiry" model="ir.cron">
            <field name="name">Production Estimation Expiry</field>
            <field name="model_id" ref="model_mrp_estimation"/>
            <field name="state">code</field>
            <field name="code">model.action_expiry_estimation()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>