<odoo>
    <data>
        <record id="mrp_estimation_inherit_form" model="ir.ui.view">
            <field name="name">mrp.estimation.inherit</field>
            <field name="model">mrp.estimation</field>
            <field name="inherit_id" ref="fnet_mrp.mrp_estimation_form_view"/>
            <field name="arch" type="xml">
                <field name="product_id" position="after">
                    <field name="sale_order_id"/>
                    <field name="sale_order_line_id" invisible="1"/>
                    <field name="sale_state"/>
                </field>
                <xpath expr="//sheet" position="before">
                    <header>
                        <button name="action_confirm_delivery_date" string="Delivery Date Confirm" type="object" class="btn-primary" invisible="sale_state not in ('draft', 'sent') or state != 'draft'"/>
                        <button name="action_create_mrp_plan" string="Create Production" type="object" class="btn-success" invisible="state != 'delivery_date_sent' or sale_state != 'sale'"/>
                    </header>
                </xpath>
            </field>
        </record>


        <record id="mrp_delivery_form_view" model="ir.ui.view">
            <field name="name">mrp.delivery.view.form</field>
            <field name="model">mrp.delivery</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" string="Reference"/>
                            <h1>
                                <field name="name" required="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="company_id" invisible="1"/>
                                <field name="model_id"/>
                                <field name="product_qty"/>
                            </group>
                            <group>
                                <field name="days_full"/>
                                <field name="days_partial"/>
                                <field name="days_no"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="BOM">
                                <field name="line_ids">
                                    <list editable="bottom">
                                        <field name="company_id" column_invisible="1"/>
                                        <field name="product_uom_category_id" column_invisible="1"/>
                                        <field name="product_id"/>
                                        <field name="product_uom_id"/>
                                        <field name="product_qty" string="Required Qty"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="mrp_delivery_list_view" model="ir.ui.view">
            <field name="name">mrp.delivery.view.list</field>
            <field name="model">mrp.delivery</field>
            <field name="arch" type="xml">
                <list>
                    <field name="model_id"/>
                    <field name="product_qty"/>
                </list>
            </field>
        </record>


        <record id="mrp_delivery_action" model="ir.actions.act_window">
            <field name="name">BOM</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">mrp.delivery</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No record found. Let's create one!
                </p>
            </field>
        </record>
        <menuitem id="menu_mrp_delivery_bom" name="BOM" parent="sale.product_menu_catalog" action="mrp_delivery_action" sequence="30"/>

    </data>
</odoo>