<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.module.category" id="module_category_vendor_evaluation">
        <field name="name">Vendor Evaluation</field>
        <field name="sequence">7</field>
    </record>
      <record id="privilege_vendor_evaulation" model="res.groups.privilege">
            <field name="name">Vendor Evaluation</field>
            <field name="sequence">7</field>
