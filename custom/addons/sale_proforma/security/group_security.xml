    <record id="group_reviewer_evaluation_reviewer" model="res.groups">
        <field name="name">Reviewer</field>
        <field name="privilege_id" ref="privilege_vendor_evaulation"/>
    </record>
    <record id="group_customer_evaluation_officer" model="res.groups">
        <field name="name">Officer</field>
        <field name="privilege_id" ref="privilege_vendor_evaulation"/>
        <field name="implied_ids" eval="[(4,ref('group_reviewer_evaluation_reviewer'))]"/>
    </record>
    <record id="group_customer_evaluation_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_vendor_evaulation"/>
        <field name="implied_ids" eval="[(4,ref('group_customer_evaluation_officer'))]"/>
    </record>
