<odoo>
        <record id="view_sale_order_inherited_form" model="ir.ui.view">
            <field name="name">view_sale_order_inherited_form</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='payment_term_id']" position="before">
                    <field name="sample_sale"/>
                    <field name="proforma_invoice"/>
                    <field name="proforma_no"/>
                </xpath>
            </field>
        </record>
        <record id="sale.action_quotations_with_onboarding" model="ir.actions.act_window">
            <field name="name">Quotations</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">sale.order</field>
            <field name="view_id" ref="sale.view_quotation_tree_with_onboarding"/>
            <field name="view_mode">list,kanban,form,calendar,pivot,graph,activity</field>
            <field name="search_view_id" ref="sale.sale_order_view_search_inherit_quotation"/>
            <field name="domain">[('sample_sale', '!=', True)]</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new quotation, the first step of a new sale!
                </p>
                <p>
                    Once the quotation is confirmed by the customer, it becomes a sales order.
                    <br/>
                    You will be able to create an invoice and collect the payment.
                </p>
            </field>
        </record>
        <record id="action_sale_orders_inherit" model="ir.actions.act_window">
            <field name="name">Sample Sales Orders</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">sale.order</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="sale.sale_order_view_search_inherit_sale"/>
            <field name="context">{'default_sample_sale':1}</field>
            <field name="domain">[('sample_sale', '=', True)]</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new quotation, the first step of a new sale!
                </p>
                <p>
                    Once the quotation is confirmed, it becomes a sales order.
                    <br/>
                    You will be able to create an invoice and collect the payment.
                </p>
            </field>
        </record>
        <record id="view_order_form_inherit" model="ir.ui.view">
            <field name="name">sale.order.form.inherit</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="(//button[@name='%(sale.action_view_sale_advance_payment_inv)d'])[1]" position="attributes">
                    <attribute name="invisible">sample_sale == True or invoice_status != 'to invoice'</attribute>
                </xpath>

                <xpath expr="(//button[@name='%(sale.action_view_sale_advance_payment_inv)d'])[2]" position="attributes">
                    <attribute name="invisible">sample_sale == True or invoice_status != 'no' or state != 'sale'
                    </attribute>
                </xpath>
            </field>
        </record>

        <menuitem id="menu_sale_order_sample_sale" name="Sample Sales" sequence='4' action="action_sale_orders_inherit" parent="sale.sale_order_menu"/>


        <record id="view_company_form_new" model="ir.ui.view">
            <field name="name">res.company.form</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='vat']" position="attributes">
                    <attribute name="string">GST IN</attribute>
                </xpath>
            </field>
        </record>

