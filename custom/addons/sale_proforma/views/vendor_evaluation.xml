<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_Vendor_Evaluation_tree" model="ir.ui.view">
        <field name="name">vendor.evaluation.tree</field>
        <field name="model">partner.evaluation</field>
        <field name="arch" type="xml">
            <list decoration-danger="state=='cancel'" decoration-success="state=='done'">
                <field name="vendor_code"/>
                <field name="name_of_supplier"/>
                <field name="state" widget="badge" decoration-danger="state=='cancel'" decoration-success="state=='done'"/>
            </list>
        </field>
    </record>
    <record id="view_sale_Vendor_Evaluation_form" model="ir.ui.view">
        <field name="name">vendor.evaluation.form</field>
        <field name="model">partner.evaluation</field>
        <field name="arch" type="xml">
            <form>
                <center>
                    <h1>
                        VENDOR REGISTRATION &amp; EVALUATION FORM
                    </h1>
                </center>
                <header>
                    <!--options="{'clickable':'1'}"-->
                    <!--<button name="action_draft" string="set to draft" type="object" class="oe_highlight" invisible="state != 'cancel'"/>-->
                    <button name="action_sent" string="Request" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_validate1" string="Review" type="object" groups="sale_proforma.group_reviewer_evaluation_reviewer" class="oe_highlight" invisible="state != 'sent'"/>
                    <button name="action_validate2" string="First Approval" type="object" groups="sale_proforma.group_customer_evaluation_officer" class="oe_highlight" invisible="state != 'validate1'"/>
                    <button name="action_validate3" string="Final Approval" type="object" groups="sale_proforma.group_customer_evaluation_manager" class="oe_highlight" invisible="state != 'validate2'"/>
<!--                    <button name="action_done" string="done" type="object" class="oe_highlight" invisible="state != 'cancel'"/>-->
                    <button name="action_cancel" string="Cancel" type="object" class="oe_highlight" invisible="state not in ('draft', 'validate1', 'validate2')"/>
                    <!--
                        invisible="state == 'draft' or groups == 'sale_proforma.group_reviewer_evaluation_reviewer'
                                   or state != 'draft' or groups == 'sale_proforma.group_customer_evaluation_officer'"
                    -->
                    <field name="state" widget="statusbar" statusbar_visible="draft,sent,validate1,validate2,validate3,cancel" nolabel="1"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_vendor" type="object" string="Vendor" icon="fa-sitemap" class="oe_stat_button"></button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="vendor_code" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <h1>
                                <field name="name_of_supplier" placeholder="Name of the Supplier" class="oe_highlight" colspan="2"/>
                            </h1>
                        </group>
                    </group>
                    <group>
                        <group>
                            <span class="o_form_label o_td_label" name="address_name">
                                <b>Address</b>
                            </span>
                            <div class="o_address_format" string="Address">
                                <field name="street1" placeholder="Street..." class="o_address_street"/>
                                <field name="street2" placeholder="Street 2..." class="o_address_street"/>
                                <field name="city" placeholder="City" class="o_address_city"/>
                                <field name="state_id" class="o_address_state" placeholder="State" options='{"no_open": True}'/>
                                <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                                <field name="country_id" placeholder="Country" class="o_address_country" options='{"no_open": True, "no_create": True}'/>
                            </div>
                            <field name="contact_no"/>
                            <field name="mail"/>
                            <field name="website" widget="url"/>
                            <field name="legal_name"/>
                            <field name="representative_name"/>
                            <field name="pan_no"/>
                            <field name="years"/>
                            <field name="requested_by"/>
                        </group>
                        <group>
                            <field name="organisation_name"/>
                            <field name="bussiness_name"/>
                            <field name="annual_profit"/>
                            <field name="registered"/>
                            <field name="udyam_no"/>
                            <field name="description"/>
                            <field name="bank_name"/>
                            <field name="account_no"/>
                            <field name="ifsc_code"/>
                            <field name="gst_in"/>
                            <field name="gst_treatment"/>
                        </group>
                    </group>
                    <div>
                        <center>
                            <h1>Vendor Evaluation</h1>
                        </center>
                    </div>
                    <group>
                        <group string="Vendor Evaluation">

                            <!-- Sample Submitted -->
                            <field name="sample" widget="boolean"/>
                            <field name="sample_remarks" string="Sample Remarks" invisible="not sample" options="{'rows': 2}"/>

                            <!-- All Specification Matched -->
                            <field name="all_matched" widget="boolean"/>
                            <field name="all_matched_remarks" string="Remarks" invisible="not all_matched" options="{'rows': 2}"/>

                            <!-- Trial Order Issued -->
                            <field name="trial" widget="boolean"/>
                            <field name="trial_remarks" string="Remarks" invisible="not trial" options="{'rows': 2}"/>

                            <!-- Pricing -->
                            <field name="pricing" widget="boolean"/>
                            <field name="performance_review_remarks" string="Remarks" invisible="not pricing" options="{'rows': 2}"/>
                        </group>
                        <group string="Performance Review">
                            <!-- Performance Review Header -->
                            <!-- a) All Supplied items -->
                            <field name="performance_review" widget="boolean"/>
                            <field name="material_review_remarks" string="Remarks" invisible="not performance_review" options="{'rows': 2}"/>

                            <!-- b) Material received on time -->
                            <field name="material_review" widget="boolean"/>
                            <field name="supplies_review_remarks" string="Remarks" invisible="not material_review" options="{'rows': 2}"/>

                            <!-- c) Supplied can be continued -->
                            <field name="supplies_review" widget="boolean"/>
                            <field name="pricing_remarks" string="Remarks" invisible="not supplies_review" options="{'rows': 2}"/>

                            <!-- Bottom fields -->
                            <field name="Re_ability"/>
                            <field name="over_all"/>

                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_vendor_evaluation" model="ir.actions.act_window">
        <field name="name">Vendor Evaluation</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">partner.evaluation</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="domain">[]</field>
        <field name="help" type="html">
            <p class="o_view_no content_smiling_face">
                created a vendor creation form!
            </p>
        </field>
    </record>
    <record id="view_rack_list" model="ir.ui.view">
