    <record id="view_partner_inherited_button_form" model="ir.ui.view">
        <field name="name">view_partner_inherited_button_form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button class="oe_stat_button" type="object" name="action_vendor_evaluation" string='Vendor Evaluation' icon="fa-pencil"></button>
            </div>
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="vendor_id"/>
            </xpath>
        </field>
    </record>

